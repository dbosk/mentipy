def test_auto_layout_separates_presentation_and_article_output(
    tmp_path, monkeypatch
):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    rendered = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir="build",
        layout="auto",
    )

    [entry] = store.all_questions()
    prefix = entry["url_prefix"]
    presentation = rendered.split("\\mode<presentation>{%\n", 1)[1].split(
        "\n}\n\\mode<article>{%\n",
        1,
    )[0]
    article = rendered.split("\\mode<article>{%\n", 1)[1].rsplit("\n}", 1)[0]

    assert "\\begin{columns}[T,onlytextwidth]" in presentation
    assert f"\\input{{build/Q-{prefix}.pdf_tex}}" in presentation
    assert "How was the lecture?" in article
    assert f"\\texttt{{http://example.test:8080/{prefix}}}" in article
    assert "\\input" not in article
    assert "\\begin{minipage}" not in article


