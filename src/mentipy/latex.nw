The slide default remains unchanged, but the article family now has a flat
handout layout, a QR-carrying variant, and a mode-aware Beamer renderer.

<<test functions>>=
def test_article_qr_layout_prints_the_canonical_url(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    rendered = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir="build",
        layout="article+qr",
    )

    [entry] = store.all_questions()
    prefix = entry["url_prefix"]
    sidecar = tmp_path / "build" / f"Q-{prefix}.pdf_tex"

    assert "\\begin{minipage}[t]" in rendered
    assert rendered.count("\\vspace{0pt}") == 2
    assert "\\begin{columns}[T,onlytextwidth]" not in rendered
    assert f"\\input{{build/Q-{prefix}.pdf_tex}}" in rendered
    assert sidecar.exists()
    assert f"http://example.test:8080/{prefix}" in sidecar.read_text()


def test_article_layout_is_flat_and_qrless(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    rendered = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir="build",
        layout="article",
    )

    [entry] = store.all_questions()
