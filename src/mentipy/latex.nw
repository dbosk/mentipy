The default tests pin the existing slide contract: each helper must register the
question, write the QR code to the configured build directory, and mention that
file in the returned LaTeX.

<<test functions>>=
def test_mc_registers_the_question_and_references_the_qr(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    rendered = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir="build",
    )

    [entry] = store.all_questions()
    prefix = entry["url_prefix"]

    assert "How was the lecture?" in rendered
    assert f"\\input{{build/Q-{prefix}.pdf_tex}}" in rendered
    assert (tmp_path / "build" / f"Q-{prefix}.pdf").exists()
    assert (tmp_path / "build" / f"Q-{prefix}.pdf_tex").exists()


def test_open_text_registers_the_question_and_references_the_qr(
    tmp_path, monkeypatch
):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    rendered = open_text(
        "One thing to change?",
        max_chars=140,
        store=store,
        base_url="http://example.test:8080",
        qr_dir="build",
    )

    [entry] = store.all_questions()
    prefix = entry["url_prefix"]

    assert "One thing to change?" in rendered
    assert f"\\input{{build/Q-{prefix}.pdf_tex}}" in rendered
    assert store.resolve(prefix) == entry["hash"]


def test_scale_registers_the_question_and_references_the_qr(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    rendered = scale(
        "Pace?",
        low_label="Too slow",
        high_label="Too fast",
        store=store,
        base_url="http://example.test:8080",
        qr_dir="build",
    )

    [entry] = store.all_questions()
    prefix = entry["url_prefix"]

    assert "Pace?" in rendered
    assert f"\\input{{build/Q-{prefix}.pdf_tex}}" in rendered
    assert store.question(entry["hash"]).kind == "scale"


def test_question_resolves_local_ip_when_base_url_unset(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    monkeypatch.setenv("MENTIPY_CONFIG", str(tmp_path / "config.json"))
    set_setting("port", 9123)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    called = {}

    def fake_resolve(value, port):
        called["value"] = value
        called["port"] = port
        return f"http://192.0.2.25:{port}"

    monkeypatch.setattr("mentipy.latex.resolve_base_url", fake_resolve)

    rendered = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        qr_dir="build",
        layout="article",
    )

    [entry] = store.all_questions()
    prefix = entry["url_prefix"]

    assert called == {"value": None, "port": 9123}
    assert f"\\texttt{{http://192.0.2.25:9123/{prefix}}}" in rendered
