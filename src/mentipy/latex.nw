\subsection{QR regeneration}

The server-side QR regeneration path should rewrite every registered question,
because the public base URL changes independently of the slide source.

<<test functions>>=
def test_regenerate_qrs_rewrites_every_registered_question(tmp_path, monkeypatch):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    first = store.register(OpenQuestion("One thing to change?"))
    second = store.register(OpenQuestion("What should we repeat?"))
    calls = []

    def fake_make_qr(url, out_path, fmt="pdf", include_path=None):
        calls.append((url, Path(out_path), fmt, Path(include_path)))
        return Path(out_path)

    monkeypatch.setattr("mentipy.latex.make_qr", fake_make_qr)

    count = regenerate_qrs(store, "http://public.example:9000", qr_dir=tmp_path)

    assert count == 2
    assert calls == [
        (
            f"http://public.example:9000/{first}",
            tmp_path / f"Q-{first}.pdf",
            "pdf",
            tmp_path / f"Q-{first}.pdf",
        ),
        (
            f"http://public.example:9000/{second}",
            tmp_path / f"Q-{second}.pdf",
            "pdf",
            tmp_path / f"Q-{second}.pdf",
        ),
    ]
@

Remembered QR paths matter when the same question has been rendered into more
than one document or file format.  Regeneration must refresh every remembered
artifact and preserve the document-relative include path for each sidecar.


<<test functions>>=
def test_regenerate_qrs_reuses_all_remembered_qr_targets(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir="slides",
    )
    mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir="handout",
        qr_format="png",
    )

    [entry] = store.all_questions()
    full_hash = entry["hash"]
    prefix = entry["url_prefix"]
    assert store.qr_targets(full_hash) == [
        tmp_path / "slides" / f"Q-{prefix}.pdf",
        tmp_path / "handout" / f"Q-{prefix}.png",
    ]

    calls = []

    def fake_make_qr(url, out_path, fmt="pdf", include_path=None):
        calls.append((url, Path(out_path), fmt, Path(include_path)))
        return Path(out_path)

    monkeypatch.setattr("mentipy.latex.make_qr", fake_make_qr)

    count = regenerate_qrs(store, "http://public.example:9000")

    assert count == 2
    assert calls == [
        (
            f"http://public.example:9000/{prefix}",
            tmp_path / "slides" / f"Q-{prefix}.pdf",
            "pdf",
            Path("slides") / f"Q-{prefix}.pdf",
        ),
        (
            f"http://public.example:9000/{prefix}",
            tmp_path / "handout" / f"Q-{prefix}.png",
            "png",
            Path("handout") / f"Q-{prefix}.png",
        ),
    ]
