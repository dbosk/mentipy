def test_environment_from_config_wraps_every_layout(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    monkeypatch.setenv("MENTIPY_CONFIG", str(tmp_path / "config.json"))
    set_setting("question_environment", "exercise")
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    slide = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir=DEFAULT_QR_DIR,
        layout="slide",
    )
    article = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir=DEFAULT_QR_DIR,
        layout="article",
    )
    article_qr = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir=DEFAULT_QR_DIR,
        layout="article+qr",
    )
    auto = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir=DEFAULT_QR_DIR,
        layout="auto",
    )

    assert "\\begin{exercise}" in slide
    assert "\\textbf{" not in slide
    assert slide.index("\\end{exercise}") < slide.index("\\input")

    assert "\\begin{exercise}" in article
    assert "\\textbf{" not in article
    assert "\\input" not in article

    assert "\\begin{exercise}" in article_qr
    assert "\\textbf{" not in article_qr
    assert article_qr.index("\\end{exercise}") < article_qr.index("\\input")

    assert auto.count("\\begin{exercise}") == 2
    assert auto.count("\\end{exercise}") == 2
    assert "\\textbf{" not in auto
    assert "\\mode<presentation>{" in auto
    assert "\\mode<article>{" in auto
    article_branch = auto.split("\\mode<article>{%\n", 1)[1]
    assert "\\input" not in article_branch
