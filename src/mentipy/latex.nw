QR-bearing layouts deliberately keep the sidecar caption even when [[show_url]]
is false.  The QR matrix and printed caption are regenerated as a pair, so
removing only the caption would make the sidecar less useful after URL rewrites.


<<test functions>>=
def test_article_qr_layout_keeps_the_sidecar_url_caption(tmp_path, monkeypatch):
    monkeypatch.chdir(tmp_path)
    store = Store(tmp_path / "mentipy.json", min_prefix=4)

    rendered = mc(
        "How was the lecture?",
        ["Great", "OK", "Boring"],
        store=store,
        base_url="http://example.test:8080",
        qr_dir=DEFAULT_QR_DIR,
        layout="article+qr",
        show_url=False,
    )

    [entry] = store.all_questions()
    prefix = entry["url_prefix"]
    sidecar = tmp_path / DEFAULT_QR_DIR / f"Q-{prefix}.pdf_tex"

    assert f"\\input{{{QR_SUBPATH}/Q-{prefix}.pdf_tex}}" in rendered
    assert sidecar.exists()
    assert f"http://example.test:8080/{prefix}" in sidecar.read_text()
