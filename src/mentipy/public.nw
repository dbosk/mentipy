The UPnP path is mostly wiring around the third-party client.  A fake module is
enough to pin the contract without talking to a real router.

<<test functions>>=
def test_expose_upnp_maps_the_requested_port(monkeypatch):
    called = {}

    class FakeUPnP:
        lanaddr = "192.0.2.10"

        def __init__(self):
            self.discoverdelay = None

        def discover(self):
            called["discoverdelay"] = self.discoverdelay
            return 1

        def selectigd(self):
            called["selected"] = True

        def addportmapping(
            self, external_port, protocol, local_host, local_port, description, _
        ):
            called["mapping"] = (
                external_port,
                protocol,
                local_host,
                local_port,
                description,
            )
            return True

        def deleteportmapping(self, _external_port, _protocol):
            return None

    monkeypatch.setitem(
        sys.modules,
        "miniupnpc",
        types.SimpleNamespace(UPnP=FakeUPnP),
    )
    monkeypatch.setattr("mentipy.public.resolve_public_ip", lambda: "198.51.100.8")

    public_url = expose_upnp(8080)

    assert public_url == "http://198.51.100.8:8080"
    assert called["discoverdelay"] == UPNP_DISCOVER_DELAY_MS
    assert called["selected"] is True
    assert called["mapping"] == (
        8080,
        UPNP_PROTOCOL,
        "192.0.2.10",
        8080,
        UPNP_DESCRIPTION,
    )
