def test_expose_ssh_rejects_tunnels_that_exit_during_startup(monkeypatch):
    class FakeProcess:
        def __init__(self):
            self.stderr = io.StringIO(
                "remote port forwarding failed\n"
                "for listen port 9000\n"
            )

        def wait(self, timeout):
            assert timeout == SSH_STARTUP_TIMEOUT
            return 255

    monkeypatch.setattr(
        public_module.subprocess,
        "Popen",
        lambda *_args, **_kwargs: FakeProcess(),
    )

    with pytest.raises(PublicExposureError) as err:
        expose_ssh(8080, "alice@example.test:9000")

    message = str(err.value)
    assert "status 255" in message
    assert "remote port forwarding failed for listen port 9000" in message
    assert "\n" not in message


def test_expose_ssh_logs_stderr_lines_after_startup(caplog):
    class FakeProcess:
        def __init__(self):
            self.stderr = io.StringIO("first line\nsecond line\n")

        def poll(self):
            return 0

    with caplog.at_level(logging.ERROR, logger="mentipy.public"):
        public_module._drain_ssh_stderr(FakeProcess())

    assert [record.message for record in caplog.records] == [
        "ssh: first line",
        "ssh: second line",
    ]


def test_drain_ssh_stderr_reaps_a_finished_process(caplog):
    class FakeProcess:
        def __init__(self):
            self.stderr = io.StringIO("")
            self.returncode = None
            self.wait_timeouts = []

        def poll(self):
            return self.returncode

        def wait(self, timeout):
            self.wait_timeouts.append(timeout)
            self.returncode = 255
            return self.returncode

    process = FakeProcess()

    with caplog.at_level(logging.ERROR, logger="mentipy.public"):
        public_module._drain_ssh_stderr(process)

    assert process.wait_timeouts == [SSH_SHUTDOWN_TIMEOUT]
    assert [record.message for record in caplog.records] == [
        "ssh tunnel exited (status 255)",
    ]


def test_expose_ssh_rejects_malformed_endpoints():
