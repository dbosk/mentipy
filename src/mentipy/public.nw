def test_resolve_public_ip_reads_the_ipify_response(monkeypatch):
    class FakeResponse:
        def __enter__(self):
            return self

        def __exit__(self, _exc_type, _exc, _tb):
            return False

        def read(self):
            return b"198.51.100.4\n"

    monkeypatch.setattr(
        public_module.urllib.request,
        "urlopen",
        lambda url, timeout: FakeResponse(),
    )

    assert resolve_public_ip() == "198.51.100.4"


def test_resolve_public_ip_wraps_network_errors(monkeypatch):
    def fail(_url, timeout):
        raise public_module.urllib.error.URLError("offline")

    monkeypatch.setattr(public_module.urllib.request, "urlopen", fail)

    with pytest.raises(PublicExposureError):
        resolve_public_ip()
