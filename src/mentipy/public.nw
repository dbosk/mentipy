Finally, the public context manager must actually run its teardown hook when
the server stops.

<<test functions>>=
def test_expose_context_manager_runs_cleanup(monkeypatch):
    state = {}

    class FakeUPnP:
        lanaddr = "192.0.2.10"

        def __init__(self):
            self.discoverdelay = None

        def discover(self):
            return 1

        def selectigd(self):
            return None

        def addportmapping(
            self, _external_port, _protocol, _local_host, _local_port, _desc, _
        ):
            return True

        def deleteportmapping(self, external_port, protocol):
            state["deleted"] = (external_port, protocol)

    monkeypatch.setitem(
        sys.modules,
        "miniupnpc",
        types.SimpleNamespace(UPnP=FakeUPnP),
    )
    monkeypatch.setattr("mentipy.public.resolve_public_ip", lambda: "198.51.100.9")

    with expose(PublicMode.upnp, 8080) as public_url:
        assert public_url == "http://198.51.100.9:8080"
        assert "deleted" not in state

    assert state["deleted"] == (8080, UPNP_PROTOCOL)
