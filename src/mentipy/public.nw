The SSH path is pure stdlib, so small fake processes can pin the command line,
the startup diagnostics, and the long-lived stderr handling without talking to
a real SSH server.

<<test functions>>=
def test_expose_ssh_starts_a_reverse_tunnel(monkeypatch):
    called = {}

    class FakeConnection:
        def __enter__(self):
            called["connection_entered"] = True
            return self

        def __exit__(self, _exc_type, _exc, _tb):
            called["connection_exited"] = True
            return False

    class FakeProcess:
        def __init__(self):
            self.stderr = io.StringIO("")

        def poll(self):
            return None

        def wait(self, timeout):
            called["startup_timeout"] = timeout
            raise public_module.subprocess.TimeoutExpired(["ssh"], timeout)

    class FakeThread:
        def __init__(self, *, target, args, daemon, name):
            called["thread_target"] = target
            called["thread_args"] = args
            called["thread_daemon"] = daemon
            called["thread_name"] = name

        def start(self):
            called["thread_started"] = True

    def fake_popen(command, **kwargs):
        called["command"] = command
        called["kwargs"] = kwargs
        return FakeProcess()

    def fake_create_connection(address, timeout):
        called["connection"] = (address, timeout)
        return FakeConnection()

    monkeypatch.setattr(public_module.subprocess, "Popen", fake_popen)
    monkeypatch.setattr(
        public_module.socket, "create_connection", fake_create_connection
    )
    monkeypatch.setattr(public_module.threading, "Thread", FakeThread)

    process, public_url = expose_ssh(8080, "alice@example.test:9000")

    assert process.__class__.__name__ == "FakeProcess"
    assert public_url == "http://example.test:9000"
    assert called["command"] == [
        "ssh",
        "-N",
        "-R",
        "9000:localhost:8080",
        "-o",
        "ExitOnForwardFailure=yes",
        "-o",
        f"ServerAliveInterval={SSH_KEEPALIVE_SECONDS}",
        "alice@example.test",
    ]
    assert called["kwargs"]["stdout"] is public_module.subprocess.DEVNULL
    assert called["kwargs"]["stderr"] is public_module.subprocess.PIPE
    assert called["kwargs"]["text"] is True
    assert called["startup_timeout"] == SSH_STARTUP_TIMEOUT
    assert called["connection"] == (("example.test", 9000), SSH_PREFLIGHT_TIMEOUT)
    assert called["connection_entered"] is True
    assert called["connection_exited"] is True
    assert called["thread_target"] is public_module._drain_ssh_stderr
    assert called["thread_args"] == (process,)
    assert called["thread_daemon"] is True
    assert called["thread_name"] == "mentipy-ssh-stderr"
    assert called["thread_started"] is True


