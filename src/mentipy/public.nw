We keep the external echo service, the UPnP tuning, and the SSH startup,
keepalive, and shutdown timings as named constants so the behaviour stays
explicit in both tests and user-facing errors.  The same bucket also holds a
module logger so late SSH failures can reuse Python's normal stderr handling.

<<constants>>=
IPIFY_URL = "https://api.ipify.org"
PUBLIC_IP_TIMEOUT = 5
UPNP_DISCOVER_DELAY_MS = 200
UPNP_PROTOCOL = "TCP"
UPNP_DESCRIPTION = "mentipy"
SSH_KEEPALIVE_SECONDS = 30
SSH_STARTUP_TIMEOUT = 1
SSH_SHUTDOWN_TIMEOUT = 5
LOGGER = logging.getLogger(__name__)
@

The CLI only needs a small enum and a typed failure mode.  The implementation
details stay below this public surface.

<<classes>>=
class PublicMode(str, Enum):
    """Supported strategies for public exposure."""

    upnp = "upnp"
    ssh = "ssh"


class PublicExposureError(RuntimeError):
    """Raised when mentipy cannot expose the local server."""
@

Both the UPnP and SSH strategies need a public address that respondents can
reach.  A small HTTP echo service is enough for that, and wrapping the network
failure lets the CLI present a short diagnostic instead of a traceback.

<<functions>>=
def resolve_public_ip() -> str:
    """Return the current public IP address."""

    try:
        with urllib.request.urlopen(IPIFY_URL, timeout=PUBLIC_IP_TIMEOUT) as response:
            return response.read().decode("utf-8").strip()
    except (OSError, urllib.error.URLError) as err:
        raise PublicExposureError(
            "could not resolve the public IP address"
        ) from err
@

The UPnP dependency stays optional because only one of the public modes needs
it, and many users will never expose a lecture outside their own machine.  The
private helper returns both the URL and a teardown callback so the public
context manager can remove the mapping on shutdown.

<<functions>>=
def _upnp_mapping(port: int) -> tuple[str, Callable[[], None]]:
    try:
        import miniupnpc
    except ImportError as err:
        raise PublicExposureError(
            "UPnP support is optional; install with: pip install mentipy[public]"
        ) from err

    upnp = miniupnpc.UPnP()
    upnp.discoverdelay = UPNP_DISCOVER_DELAY_MS

    try:
        if upnp.discover() == 0:
            raise PublicExposureError("no UPnP gateway answered discovery")
        upnp.selectigd()
        mapped = upnp.addportmapping(
            port,
            UPNP_PROTOCOL,
            upnp.lanaddr,
            port,
            UPNP_DESCRIPTION,
            "",
        )
    except PublicExposureError:
        raise
    except Exception as err:
        raise PublicExposureError("could not create a UPnP port mapping") from err

    if not mapped:
        raise PublicExposureError("the router rejected the UPnP port mapping")

    def cleanup():
        try:
            upnp.deleteportmapping(port, UPNP_PROTOCOL)
        except Exception:
            return

    try:
        public_ip = resolve_public_ip()
    except PublicExposureError:
        cleanup()
        raise

    return f"http://{public_ip}:{port}", cleanup


def expose_upnp(port: int) -> str:
    """Expose ``port`` through UPnP and return the public URL."""

    public_url, _cleanup = _upnp_mapping(port)
    return public_url
@

The SSH endpoint needs two views of the same configuration string: the full
[[user@host]] target that the [[ssh]] command needs, and the bare host that the
audience-facing URL should contain.

Starting the child process is not enough to trust that URL.  [[ssh]] still has
to authenticate and install the reverse forward, and
[[ExitOnForwardFailure=yes]] reports setup problems by exiting the child.  Even
after that grace period, the SSH server can still keep the reverse port on
[[127.0.0.1]] or behind a firewall.  We therefore wait through a short
startup grace period and then probe the advertised [[host:remote_port]] before
we print a public URL.

<<functions>>=
def _parse_ssh_endpoint(ssh_endpoint: str) -> tuple[str, str, int]:
    target, separator, raw_port = ssh_endpoint.rpartition(":")
    if not target or not separator or not raw_port or "@" not in target:
        raise PublicExposureError(
            "ssh tunnel must look like user@host:remote_port"
        )

    user, host = target.split("@", 1)
    if not user or not host:
        raise PublicExposureError(
            "ssh tunnel must look like user@host:remote_port"
        )

    try:
        remote_port = int(raw_port)
    except ValueError as err:
        raise PublicExposureError(
            "ssh tunnel must end with a numeric remote port"
        ) from err

    if remote_port <= 0:
        raise PublicExposureError("ssh tunnel port must be positive")

    return target, host, remote_port

@

The startup grace period only tells us that the SSH client stayed alive.  A
reverse forward can still be useless if [[sshd]] leaves it on [[127.0.0.1]] or
if a host firewall blocks the chosen port.  A short TCP probe back to
[[host:remote_port]] catches those server-side failures before we print the
URL.  The probe only needs the handshake: [[sshd]] accepts first and only then
opens the channel back to [[localhost:local_port]], so the local HTTP server
does not need to be listening yet.

<<constants>>=
SSH_PREFLIGHT_TIMEOUT = 5
@

<<functions>>=
def _preflight_ssh_tunnel(host: str, remote_port: int) -> None:
    """Verify that ``host:remote_port`` accepts TCP from this machine."""

    try:
        with socket.create_connection(
            (host, remote_port), timeout=SSH_PREFLIGHT_TIMEOUT
        ):
            return
    except OSError as err:
        raise PublicExposureError(
            f"could not reach {host}:{remote_port} from this machine; "
            "check that sshd has 'GatewayPorts yes' and that the host "
            "firewall allows inbound TCP on the forwarded port"
        ) from err


def expose_ssh(
    local_port: int, ssh_endpoint: str
) -> tuple[subprocess.Popen[str], str]:
    """Expose ``local_port`` through an SSH reverse tunnel."""

    target, host, remote_port = _parse_ssh_endpoint(ssh_endpoint)
    command = [
        "ssh",
        "-N",
        "-R",
        f"{remote_port}:localhost:{local_port}",
        "-o",
        "ExitOnForwardFailure=yes",
        "-o",
        f"ServerAliveInterval={SSH_KEEPALIVE_SECONDS}",
        target,
    ]

    try:
        process = subprocess.Popen(
            command,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            text=True,
        )
    except OSError as err:
        raise PublicExposureError("could not start the SSH reverse tunnel") from err

    try:
        returncode = process.wait(timeout=SSH_STARTUP_TIMEOUT)
    except subprocess.TimeoutExpired:
        try:
            _preflight_ssh_tunnel(host, remote_port)
        except PublicExposureError:
            _stop_ssh_process(process)
            raise
        threading.Thread(
            target=_drain_ssh_stderr,
            args=(process,),
            daemon=True,
            name="mentipy-ssh-stderr",
        ).start()
        return process, f"http://{host}:{remote_port}"

    stderr_text = ""
    if process.stderr is not None:
        stderr_text = " ".join(
            line.strip()
            for line in process.stderr.read().splitlines()
            if line.strip()
        )
    detail = f": {stderr_text}" if stderr_text else ""
    raise PublicExposureError(
        f"the SSH reverse tunnel exited early (status {returncode}){detail}"
    )
@

Once startup succeeds, [[ssh]] still reports later failures on stderr.  A small
reader thread can forward those lines through the module logger, and the final
[[wait()]] reaps the child when the tunnel dies.

<<functions>>=
def _drain_ssh_stderr(process: subprocess.Popen[str]) -> None:
    stream = process.stderr
    if stream is None:
        return

    try:
        for line in stream:
            stripped = line.rstrip()
            if stripped:
                LOGGER.error("ssh: %s", stripped)
    finally:
        returncode = process.poll()
        if returncode is None:
            try:
                returncode = process.wait(timeout=SSH_SHUTDOWN_TIMEOUT)
            except subprocess.TimeoutExpired:
                returncode = None
        if returncode not in (None, 0):
            LOGGER.error("ssh tunnel exited (status %s)", returncode)


def _stop_ssh_process(process: subprocess.Popen[str]):
    if process.poll() is not None:
        return

    process.terminate()
    try:
        process.wait(timeout=SSH_SHUTDOWN_TIMEOUT)
    except subprocess.TimeoutExpired:
        process.kill()
        process.wait()
@

The CLI wants one uniform [[with]]-block no matter which strategy it picked.
The context manager keeps that interface small and guarantees that teardown runs
on Ctrl-C as well as on a normal return.

<<functions>>=
@contextmanager
def expose(
    mode: PublicMode,
    local_port: int,
    *,
    ssh_endpoint: str | None = None,
) -> Iterator[str]:
    """Yield a public URL for ``local_port`` and tear it down on exit."""

    cleanup = lambda: None

    if mode is PublicMode.upnp:
        public_url, cleanup = _upnp_mapping(local_port)
    elif mode is PublicMode.ssh:
        if ssh_endpoint is None:
            raise PublicExposureError("ssh mode requires a configured endpoint")
        process, public_url = expose_ssh(local_port, ssh_endpoint)
        cleanup = lambda: _stop_ssh_process(process)
    else:
        raise PublicExposureError(f"unknown public mode: {mode!r}")

    try:
        yield public_url
    finally:
        cleanup()
