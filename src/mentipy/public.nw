def test_expose_ssh_raises_when_preflight_times_out(monkeypatch):
    called = {}

    class FakeProcess:
        def __init__(self):
            self.stderr = io.StringIO("")

        def poll(self):
            if called.get("terminated"):
                return 0
            return None

        def wait(self, timeout):
            called.setdefault("wait_timeouts", []).append(timeout)
            if timeout == SSH_STARTUP_TIMEOUT:
                raise public_module.subprocess.TimeoutExpired(["ssh"], timeout)
            return 0

        def terminate(self):
            called["terminated"] = True

        def kill(self):
            called["killed"] = True

    class FakeThread:
        def __init__(self, **_kwargs):
            called["thread_created"] = True

        def start(self):
            called["thread_started"] = True

    def fake_create_connection(address, timeout):
        called["connection"] = (address, timeout)
        raise public_module.socket.timeout("timed out")

    monkeypatch.setattr(
        public_module.subprocess,
        "Popen",
        lambda *_args, **_kwargs: FakeProcess(),
    )
    monkeypatch.setattr(
        public_module.socket, "create_connection", fake_create_connection
    )
    monkeypatch.setattr(public_module.threading, "Thread", FakeThread)

    with pytest.raises(PublicExposureError) as err:
        expose_ssh(8080, "alice@example.test:9000")

    assert "GatewayPorts yes" in str(err.value)
    assert "firewall" in str(err.value)
    assert called["connection"] == (("example.test", 9000), SSH_PREFLIGHT_TIMEOUT)
    assert called["terminated"] is True
    assert called["wait_timeouts"] == [SSH_STARTUP_TIMEOUT, SSH_SHUTDOWN_TIMEOUT]
    assert "thread_created" not in called
    assert "killed" not in called


