The SSH path is pure stdlib, so the interesting cases are the command we spawn
and the endpoint formats we accept.

<<test functions>>=
def test_expose_ssh_starts_a_reverse_tunnel(monkeypatch):
    called = {}

    class FakeProcess:
        def poll(self):
            return None

        def wait(self, timeout):
            called["startup_timeout"] = timeout
            raise public_module.subprocess.TimeoutExpired(["ssh"], timeout)

    def fake_popen(command, **kwargs):
        called["command"] = command
        called["kwargs"] = kwargs
        return FakeProcess()

    monkeypatch.setattr(public_module.subprocess, "Popen", fake_popen)

    process, public_url = expose_ssh(8080, "alice@example.test:9000")

    assert process.__class__.__name__ == "FakeProcess"
    assert public_url == "http://example.test:9000"
    assert called["command"] == [
        "ssh",
        "-N",
        "-R",
        "9000:localhost:8080",
        "-o",
        "ExitOnForwardFailure=yes",
        "-o",
        f"ServerAliveInterval={SSH_KEEPALIVE_SECONDS}",
        "alice@example.test",
    ]
    assert called["startup_timeout"] == SSH_STARTUP_TIMEOUT


def test_expose_ssh_rejects_tunnels_that_exit_during_startup(monkeypatch):
    class FakeProcess:
        def wait(self, timeout):
            assert timeout == SSH_STARTUP_TIMEOUT
            return 255

    monkeypatch.setattr(
        public_module.subprocess,
        "Popen",
        lambda *_args, **_kwargs: FakeProcess(),
    )

    with pytest.raises(PublicExposureError, match=r"status 255"):
        expose_ssh(8080, "alice@example.test:9000")


def test_expose_ssh_rejects_malformed_endpoints():
    with pytest.raises(PublicExposureError):
        expose_ssh(8080, "example.test:9000")
