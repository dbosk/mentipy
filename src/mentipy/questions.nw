The persistence shape keeps [[next]] and [[results]] explicit even at their
default values.  That lets the store refresh question data without guessing
whether an absent key belongs to the question or to store-owned metadata ---
in particular, a [[results]] override that is later removed from the slide
source must be able to revert to the deferring [[None]] on the next
recompile.

<<test functions>>=

def test_mc_question_to_dict_includes_a_default_next_flag():
    assert MCQuestion("Pick one", ("A", "B")).to_dict() == {
        "kind": "mc",
        "text": "Pick one",
        "options": ["A", "B"],
        "multi": False,
        "next": True,
        "results": None,
    }


def test_mc_question_to_dict_includes_an_opt_out_next_flag():
    payload = MCQuestion("Pick one", ("A", "B"), next=False).to_dict()
    assert payload["next"] is False
