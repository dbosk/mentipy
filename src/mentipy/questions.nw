\section{Canonicalisation}

The rest of the system works on a question union.  The helper that rebuilds a
question from stored JSON is the bridge between the typed model and the JSON
registry.

Stored JSON is less typed than the in-memory dataclasses.  We therefore coerce
[[fence]] back to [[str]] when it is present so older or hand-edited store
files still rebuild into the same [[OpenQuestion]] shape as freshly rendered
questions.

<<classes>>=
Question = MCQuestion | OpenQuestion | ScaleQuestion
@

<<functions>>=
def question_from_dict(data: Mapping[str, Any]) -> Question:
    """Rebuild a question object from stored JSON data."""

    kind = data["kind"]

    if kind == "mc":
        return MCQuestion(
            text=str(data["text"]),
            options=tuple(data["options"]),
            multi=bool(data.get("multi", False)),
        )

    if kind == "open":
        return OpenQuestion(
            text=str(data["text"]),
            max_chars=int(data.get("max_chars", 280)),
            fence=(
                None if data.get("fence") is None
                else str(data["fence"])
            ),
        )

    if kind == "scale":
        return ScaleQuestion(
            text=str(data["text"]),
            low=int(data.get("low", 1)),
            high=int(data.get("high", 5)),
            low_label=str(data.get("low_label", "")),
            high_label=str(data.get("high_label", "")),
        )

    raise ValueError(f"unknown question kind: {kind}")
@

The round-trip test fixes the storage contract.  If any field is lost or
renamed later, the test fails before old data is silently corrupted.

<<test functions>>=
@pytest.mark.parametrize(
    ("payload", "expected_type"),
    [
        (
            {
                "kind": "mc",
                "text": "How was the lecture?",
                "options": ["Great", "OK", "Boring"],
                "multi": True,
            },
            MCQuestion,
        ),
        (
            {
                "kind": "open",
                "text": "One thing to change?",
                "max_chars": 140,
            },
            OpenQuestion,
        ),
        (
            {
                "kind": "open",
                "text": "Show your code",
                "max_chars": 5000,
                "fence": "python",
            },
            OpenQuestion,
        ),
        (
            {
                "kind": "scale",
                "text": "Pace?",
                "low": 1,
                "high": 7,
                "low_label": "slow",
                "high_label": "fast",
            },
            ScaleQuestion,
        ),
    ],
)
def test_question_round_trip(payload, expected_type):
    question = question_from_dict(payload)

    assert isinstance(question, expected_type)
    assert question.to_dict() == payload
