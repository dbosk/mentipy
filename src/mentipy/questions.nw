@pytest.mark.parametrize("override", [True, False])
def test_question_from_dict_round_trips_a_results_override(override):
    questions = [
        MCQuestion("Pick one", ("A", "B"), results=override),
        OpenQuestion("Feedback?", results=override),
        ScaleQuestion("Pace?", results=override),
        WordCloudQuestion("Topic?", results=override),
        RankingQuestion("Rank these", ("A", "B"), results=override),
        PinImageQuestion(
            "Pin it", "0" * 64, "image/png", results=override
