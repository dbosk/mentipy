The multiple-choice round-trip test fixes the storage contract for option order
and the multi-select flag.  If either field is lost or renamed later, old data
would silently change meaning.

<<test functions>>=
def test_mc_question_round_trip():
    payload = {
        "kind": "mc",
        "text": "How was the lecture?",
        "options": ["Great", "OK", "Boring"],
        "multi": True,
    }

    question = question_from_dict(payload)

    assert isinstance(question, MCQuestion)
    assert question.to_dict() == payload
