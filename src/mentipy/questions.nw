    (via ``image_sha256``) together with the pin contract
    (``max_pins``, ``allow_comment``); the stored ``image_path`` and
    ``image_mime`` are presentation, as are the shared ``next`` and
    ``results`` flags.  Build instances from raw bytes with
    ``from_image_bytes``.
    """

    text: str
    image_sha256: str
    image_mime: str
    image_path: str | None = None
    max_pins: int = 1
    allow_comment: bool = False
    next: bool = True
