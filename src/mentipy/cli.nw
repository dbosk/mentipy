The command tests mostly verify wiring.  The heavy lifting has already been
tested in the lower-level modules.

<<test functions>>=
def test_config_set_get_round_trip(tmp_path, monkeypatch):
    runner = CliRunner()
    monkeypatch.setenv("MENTIPY_CONFIG", str(tmp_path / "config.json"))

    result = runner.invoke(cli, ["config", "set", "port", "9000"])
    assert result.exit_code == 0

    result = runner.invoke(cli, ["config", "get", "port"])
    assert result.exit_code == 0
    assert result.stdout.strip() == "9000"


def test_serve_command_uses_config_defaults(tmp_path, monkeypatch):
    runner = CliRunner()
    monkeypatch.setenv("MENTIPY_CONFIG", str(tmp_path / "config.json"))
    set_setting("host", "127.0.0.1")
    set_setting("port", 9001)
    set_setting("store", str(tmp_path / "answers.json"))
    called = {}

    def fake_serve(store, host, port, public_results=False):
        called["path"] = store.path
        called["host"] = host
        called["port"] = port
        called["public_results"] = public_results

    monkeypatch.setattr("mentipy.cli.serve_http", fake_serve)

    result = runner.invoke(cli, ["serve"])

    assert result.exit_code == 0
    assert called["path"] == tmp_path / "answers.json"
    assert called["host"] == "127.0.0.1"
    assert called["port"] == 9001
    assert called["public_results"] is False
