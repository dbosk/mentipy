def test_url_command_public_without_value_defaults_to_upnp(tmp_path, monkeypatch):
    runner = CliRunner()
    config_path = tmp_path / "config.json"
    monkeypatch.setenv("MENTIPY_CONFIG", str(config_path))
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(OpenQuestion("Comment?"))
    called = {}
    state = {"closed": False}

    @contextmanager
    def fake_expose(mode, local_port, *, ssh_endpoint=None):
        called["mode"] = mode
        called["local_port"] = local_port
        called["ssh_endpoint"] = ssh_endpoint
        try:
            yield "http://public.example:8080"
        finally:
            state["closed"] = True

    monkeypatch.setattr("mentipy.cli.expose", fake_expose)

    result = runner.invoke(
        cli,
        ["url", prefix, "--public", "--port", "8080", "--store", str(store.path)],
        env={"MENTIPY_CONFIG": str(config_path)},
    )

    assert result.exit_code == 0
    assert called == {
        "mode": PublicMode.upnp,
        "local_port": 8080,
        "ssh_endpoint": None,
    }
    assert state["closed"] is True
    assert WARNING_TEXT in result.stderr
    assert result.stdout.strip() == f"http://public.example:8080/{prefix}"


def test_url_command_public_prefers_public_base_url(tmp_path, monkeypatch):
    runner = CliRunner()
