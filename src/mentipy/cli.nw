The watcher intentionally owns the refresh loop rather than pushing that loop
into the store.  The display policy depends on the question kind.  Aggregate
questions redraw because their meaning is in changing counts; open questions
print the initial view once and then append only newly arrived answers, avoiding
screen flutter while keeping a chronological transcript visible.

<<cli setup>>=
@cli.command()
def watch(
    prefix: str,
    store: Optional[str] = STORE_OPTION,
    interval: float = WATCH_INTERVAL_OPTION,
):
    """Show live results for ``prefix`` in the terminal."""

    active_store = _configured_store(store)
    full_hash = _resolve_full_hash(active_store, prefix)
    console = _result_console()
    initial_results = active_store.results(full_hash)

    try:
        if initial_results["question"]["kind"] == "open":
            console.print(
                "\n".join(
                    [
                        initial_results["question"]["text"],
                        f"Prefix: {initial_results['url_prefix']}",
                        f"Responses: {initial_results['total']}",
                        "",
                    ]
                )
            )
            if initial_results["answers"]:
                _render_terminal_open_stats(initial_results, console=console)
                _render_open_answers(initial_results["answers"], console=console)
            seen = len(initial_results["answers"])
            while True:
                time.sleep(interval)
                results = active_store.results(full_hash)
                answers = results["answers"]
                if len(answers) > seen:
                    _render_open_watch_update(results, console=console)
                    _render_open_answers(
                        answers[seen:],
                        console=console,
                        start=seen + 1,
                    )
                    seen = len(answers)
        else:
            while True:
                typer.echo(CLEAR_SCREEN, nl=False)
                _render_results(active_store.results(full_hash), console=console)
                time.sleep(interval)
    except KeyboardInterrupt:
        return
@

The live command keeps refreshing until interrupted.  For multiple-choice
