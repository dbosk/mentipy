@

The watcher redraws the terminal, and the public-exposure flow prints a fixed
warning.  Keeping both strings here avoids repeating terminal-specific details
inside the command bodies.

<<constants>>=
CLEAR_SCREEN = "\033[2J\033[H"

WARNING_TEXT = (
    "Warning: exposing mentipy makes its unauthenticated polling pages\n"
    "reachable from the public internet. Anyone with the URL can submit\n"
    "answers and, with --results, watch the live tally."
)

LAYOUT_HELP = "Question layout: slide, article, article+qr, or auto."
@

The helpers below do the command-independent work: resolving prefixes,
serialising exports, and formatting live watcher output.

<<functions>>=
def _configured_store(path: str | None) -> Store:
    return Store(path or get_setting(STORE_CONFIG, DEFAULT_STORE_PATH))


def _render_common_kwargs(
    *,
    store: str | None,
    environment: str | None,
    show_url: bool | None,
    base_url: str | None,
    qr_dir: str | None,
    qr_format: str | None,
    layout: str,
) -> dict:
    return {
        "store": _configured_store(store),
        "environment": environment,
        "show_url": show_url,
        "base_url": base_url,
        "qr_dir": qr_dir,
        "qr_format": qr_format,
        "layout": layout,
    }


def _join_url(base_url: str, prefix: str) -> str:
    return f"{base_url.rstrip('/')}/{prefix}"


def _resolve_full_hash(store: Store, prefix: str) -> str:
    full_hash = store.resolve(prefix)
    if full_hash is not None:
        return full_hash

    matches = store.matches(prefix)
    if len(matches) > 1:
        raise typer.BadParameter(f"{prefix!r} matches multiple questions")
    raise typer.BadParameter(f"{prefix!r} does not match any question")


def _canonical_prefix(store: Store, prefix: str) -> str:
    full_hash = _resolve_full_hash(store, prefix)
    return store.metadata(full_hash)["url_prefix"]


def _format_value(value) -> str:
    if isinstance(value, str):
        return value
    return json.dumps(value, ensure_ascii=False)


def _watch_snapshot(store: Store, prefix: str) -> str:
    full_hash = _resolve_full_hash(store, prefix)
    results = store.results(full_hash)
    question = results["question"]
    lines = [
        question["text"],
        f"Prefix: {results['url_prefix']}",
        f"Responses: {results['total']}",
        "",
    ]

    if question["kind"] == "mc":
        for option, count in zip(question["options"], results["counts"]):
            lines.append(f"{option}: {count}")
        return "\n".join(lines)

    if question["kind"] == "scale":
        for value, count in results["counts"].items():
            lines.append(f"{value}: {count}")
        return "\n".join(lines)

    if results["answers"]:
        for answer in results["answers"]:
            lines.append(f"{answer['ts']}: {answer['value']}")
    else:
        lines.append("No answers yet.")

    return "\n".join(lines)


def _results_csv(results: dict) -> str:
    buffer = io.StringIO()
    writer = csv.writer(buffer)
    writer.writerow(["ts", "value"])

    for answer in results["answers"]:
        value = answer["value"]
        if isinstance(value, list):
            value = "|".join(str(item) for item in value)
        writer.writerow([answer["ts"], value])

    return buffer.getvalue().rstrip()


def _parse_public_mode(
    ctx: typer.Context,
    public: bool,
) -> PublicMode | None:
    extras = list(ctx.args)

    if not public:
        if extras:
            raise typer.BadParameter(
                f"unexpected extra argument {extras[0]!r}",
                param_hint="serve",
            )
        return None

    if not extras:
        return PublicMode.upnp

    try:
        mode = PublicMode(extras[0].lower())
    except ValueError as err:
        raise typer.BadParameter(
            "public mode must be either 'upnp' or 'ssh'",
            param_hint="--public",
        ) from err

    if len(extras) > 1:
        raise typer.BadParameter(
            f"unexpected extra argument {extras[1]!r}",
            param_hint="--public",
        )

    return mode


def _serve_publicly(
    active_store: Store,
    chosen_host: str,
    chosen_port: int,
    *,
    public: PublicMode,
    results: bool,
):
    typer.echo(WARNING_TEXT, err=True)

    ssh_endpoint = None
    if public is PublicMode.ssh:
        ssh_endpoint = get_setting(SSH_TUNNEL_CONFIG)
        if not ssh_endpoint:
            raise typer.BadParameter(
                f"configure {SSH_TUNNEL_CONFIG} before using ssh mode",
                param_hint="--public",
            )

    try:
        with expose(public, chosen_port, ssh_endpoint=ssh_endpoint) as derived_url:
            public_url = get_setting(PUBLIC_BASE_URL_CONFIG) or derived_url
            configured_base = get_setting(BASE_URL_CONFIG, DEFAULT_BASE_URL)

            if public_url == configured_base:
                typer.echo(f"Public URL: {public_url}")
            else:
                count = regenerate_qrs(active_store, public_url)
                typer.echo(
                    f"Public URL: {public_url}\n"
                    f"Regenerated {count} QR codes; recompile your slides so "
                    "they embed the new images."
                )

            serve_http(
                active_store,
                chosen_host,
                chosen_port,
                public_results=results,
            )
    except PublicExposureError as err:
        typer.echo(f"Could not expose the server: {err}", err=True)
        raise typer.Exit(code=1)
@

Typer lets us keep the public CLI declaration close to the implementation.

<<cli setup>>=
cli = typer.Typer(help="Self-hosted classroom polling.")
config_cli = typer.Typer(help="Read and write mentipy configuration.")
render_cli = typer.Typer(help="Render question LaTeX.")
cli.add_typer(config_cli, name="config")
cli.add_typer(render_cli, name="render")


@cli.command(context_settings={"allow_extra_args": True})
def serve(
    ctx: typer.Context,
    host: Optional[str] = typer.Option(None, help="Bind address."),
    port: Optional[int] = typer.Option(None, help="Bind port."),
    store: Optional[str] = typer.Option(None, help="Path to mentipy.json."),
    public: bool = typer.Option(
        False,
        "--public",
        help="Expose the server publicly. Bare --public defaults to upnp.",
    ),
    results: bool = typer.Option(
        False,
        "--results",
        help="Redirect respondents to the live results page.",
    ),
):
    """Run the local polling server."""

    chosen_host = host or get_setting(HOST_CONFIG, DEFAULT_HOST)
    chosen_port = int(port or get_setting(PORT_CONFIG, DEFAULT_PORT))
    active_store = _configured_store(store)
    public_mode = _parse_public_mode(ctx, public)

    if public_mode is None:
        serve_http(
            active_store,
            chosen_host,
            chosen_port,
            public_results=results,
        )
        return

    _serve_publicly(
        active_store,
        chosen_host,
        chosen_port,
        public=public_mode,
        results=results,
    )


@render_cli.command("mc")
def render_mc(
    text: str,
    options: list[str],
    multi: bool = typer.Option(False, "--multi", help="Allow multiple answers."),
    environment: Optional[str] = typer.Option(None, "--env", help="Wrap in a LaTeX environment."),
    layout: str = typer.Option("slide", "--layout", help=LAYOUT_HELP),
    url: Optional[bool] = typer.Option(None, "--url/--no-url", help="Show the printed URL when the layout supports it."),
    base_url: Optional[str] = typer.Option(None, "--base-url", help="Override the configured base URL."),
    qr_dir: Optional[str] = typer.Option(None, "--qr-dir", help="QR output directory."),
    qr_format: Optional[str] = typer.Option(None, "--qr-format", help="QR image format."),
    store: Optional[str] = typer.Option(None, help="Path to mentipy.json."),
):
    """Render a multiple-choice question as LaTeX."""

    typer.echo(
        render_mc_question(
            text,
            options,
            multi=multi,
            **_render_common_kwargs(
                store=store,
                environment=environment,
                show_url=url,
                base_url=base_url,
                qr_dir=qr_dir,
                qr_format=qr_format,
                layout=layout,
            ),
        )
    )


