\section{URL generation}

The URL command mirrors [[serve]] without starting the server.  Public mode
borrows the exposure context just long enough to print the externally reachable
address, while local mode resolves the configured or explicit base URL through
the network helper.

<<cli setup>>=
@cli.command(context_settings={"allow_extra_args": True})
def url(
    ctx: typer.Context,
    prefix: str,
    store: Optional[str] = STORE_OPTION,
    port: Optional[int] = PORT_OPTION,
    public: bool = PUBLIC_OPTION,
    base: Optional[str] = URL_BASE_OPTION,
):
    """Print the canonical poll URL for ``prefix``."""

    active_store = _configured_store(store)
    chosen_port = _configured_port(port)
    public_mode = _parse_public_mode(ctx, public, command="url")

    if public_mode is not None:
        if base is not None:
            raise typer.BadParameter(
                "cannot combine --base with --public",
                param_hint="--base",
            )
        with _public_url_context(public_mode, chosen_port) as chosen_base:
            typer.echo(
                _join_url(chosen_base, _canonical_prefix(active_store, prefix))
            )
        return

    chosen_base = resolve_base_url(_configured_base(base), chosen_port)
    typer.echo(_join_url(chosen_base, _canonical_prefix(active_store, prefix)))
