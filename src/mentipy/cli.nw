Scale questions use descriptive statistics rather than a single mode.  The
terminal callout keeps the same precision as the HTML page: two decimals for
mean and standard deviation, exact values for median and endpoints.

<<functions>>=
def _render_terminal_scale_stats(summary: dict, *, console: Console):
    if summary.get("mean") is None:
        return
    console.print(
        _stats_line(
            [
                ("Mean", f'{summary["mean"]:.2f}'),
                ("Median", f'{summary["median"]}'),
                ("Std", f'{summary["stddev"]:.2f}'),
                ("Min", f'{summary["min"]}'),
                ("Max", f'{summary["max"]}'),
            ]
        )
    )
@

