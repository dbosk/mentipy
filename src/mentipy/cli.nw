\section{Serving commands}

The local serving path resolves the address that should appear in remembered
QR codes before starting the HTTP server.  A pinned base URL is trusted as-is;
otherwise the current bind port is used to resolve a LAN-style URL and refresh
the QR artifacts that LaTeX will later include.

<<cli setup>>=
@cli.command(context_settings={"allow_extra_args": True})
def serve(
    ctx: typer.Context,
    host: Optional[str] = HOST_OPTION,
    port: Optional[int] = PORT_OPTION,
    store: Optional[str] = STORE_OPTION,
    public: bool = PUBLIC_OPTION,
    results: bool = RESULTS_OPTION,
):
    """Run the local polling server."""

    chosen_host = host or get_setting(HOST_CONFIG, DEFAULT_HOST)
    chosen_port = _configured_port(port)
    active_store = _configured_store(store)
    public_mode = _parse_public_mode(ctx, public, command="serve")

    if public_mode is None:
        configured_base = _configured_base(None)
        if configured_base not in (None, "", "auto"):
            typer.echo(f"Serving at {configured_base}")
        else:
            resolved = resolve_base_url(configured_base, chosen_port)
            count = regenerate_qrs(active_store, resolved)
            typer.echo(
                f"Serving at {resolved}\n"
                f"Regenerated {count} QR codes; recompile your slides so "
                "they embed the new images."
            )
        serve_http(
            active_store,
            chosen_host,
            chosen_port,
            public_results=results,
        )
        return

    _serve_publicly(
        active_store,
        chosen_host,
        chosen_port,
        public=public_mode,
        results=results,
    )
@

