    prefix = store.register(OpenQuestion("Comment?"))

    @contextmanager
    def fake_expose(_mode, _local_port, *, ssh_endpoint=None):
        yield "http://derived.example:8080"

    monkeypatch.setattr("mentipy.cli.expose", fake_expose)

    result = runner.invoke(
        cli,
        ["url", prefix, "--public", "--store", str(store.path)],
        env={"MENTIPY_CONFIG": str(config_path)},
    )

    assert result.exit_code == 0
    assert WARNING_TEXT in result.stderr
    assert result.stdout.strip() == f"https://polls.example/{prefix}"


def test_url_command_rejects_base_and_public_together(tmp_path):
    runner = CliRunner()
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(OpenQuestion("Comment?"))

    result = runner.invoke(
        cli,
        [
            "url",
            prefix,
            "--public",
            "--base",
            "http://example.test:8080",
            "--store",
            str(store.path),
        ],
    )

    assert result.exit_code != 0
    assert "cannot combine --base with --public" in result.output


