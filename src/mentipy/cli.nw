def test_export_json_and_csv(tmp_path):
    runner = CliRunner()
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(OpenQuestion("Comment?"))
    full_hash = store.resolve(prefix)
    store.record(full_hash, "hello")

    result = runner.invoke(cli, ["export", prefix, "--store", str(store.path)])
    assert result.exit_code == 0
    assert json.loads(result.stdout)["total"] == 1

    result = runner.invoke(
        cli,
        ["export", prefix, "--format", "csv", "--store", str(store.path)],
    )
    assert result.exit_code == 0
    assert "ts,value" in result.stdout
    assert "hello" in result.stdout


def test_url_command_uses_the_canonical_prefix(tmp_path):
    runner = CliRunner()
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(OpenQuestion("Comment?"))
    full_hash = store.resolve(prefix)

    result = runner.invoke(
        cli,
        [
            "url",
            full_hash,
            "--store",
            str(store.path),
            "--base",
            "http://example.test:8080",
        ],
    )

    assert result.exit_code == 0
    assert result.stdout.strip() == f"http://example.test:8080/{prefix}"
