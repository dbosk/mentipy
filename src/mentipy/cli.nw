Typer lets us keep the public CLI declaration close to the implementation.

<<cli setup>>=
cli = typer.Typer(help="Self-hosted classroom polling.")
config_cli = typer.Typer(help="Read and write mentipy configuration.")
cli.add_typer(config_cli, name="config")


@cli.command()
def serve(
    host: Optional[str] = typer.Option(None, help="Bind address."),
    port: Optional[int] = typer.Option(None, help="Bind port."),
    store: Optional[str] = typer.Option(None, help="Path to mentipy.json."),
    results: bool = typer.Option(
        False,
        "--results",
        help="Redirect respondents to the live results page.",
    ),
):
    """Run the local polling server."""

    chosen_host = host or get_setting(HOST_CONFIG, DEFAULT_HOST)
    chosen_port = int(port or get_setting(PORT_CONFIG, DEFAULT_PORT))
    serve_http(
        _configured_store(store),
        chosen_host,
        chosen_port,
        public_results=results,
    )


@cli.command()
def watch(
    prefix: str,
    store: Optional[str] = typer.Option(None, help="Path to mentipy.json."),
    interval: float = typer.Option(2.0, help="Refresh interval in seconds."),
):
    """Show live results for ``prefix`` in the terminal."""

    active_store = _configured_store(store)

    try:
        while True:
            typer.echo(CLEAR_SCREEN, nl=False)
            typer.echo(_watch_snapshot(active_store, prefix))
            time.sleep(interval)
    except KeyboardInterrupt:
        return


@cli.command()
def export(
    prefix: str,
    format: str = typer.Option("json", help="Output format: json or csv."),
    store: Optional[str] = typer.Option(None, help="Path to mentipy.json."),
):
    """Export answers for ``prefix``."""

    active_store = _configured_store(store)
    full_hash = _resolve_full_hash(active_store, prefix)
    results = active_store.results(full_hash)

    if format == "json":
        typer.echo(json.dumps(results, ensure_ascii=False, indent=2, sort_keys=True))
        return

    if format == "csv":
        typer.echo(_results_csv(results))
        return

    raise typer.BadParameter("format must be either 'json' or 'csv'")


@cli.command()
def url(
    prefix: str,
    store: Optional[str] = typer.Option(None, help="Path to mentipy.json."),
    base: Optional[str] = typer.Option(
        None,
        help="Override the configured base URL.",
    ),
):
    """Print the canonical poll URL for ``prefix``."""

    active_store = _configured_store(store)
    chosen_base = base or get_setting(BASE_URL_CONFIG, DEFAULT_BASE_URL)
    typer.echo(_join_url(chosen_base, _canonical_prefix(active_store, prefix)))


@config_cli.command("get")
def config_get(key: str):
    """Read a mentipy configuration value."""

    full_key = normalize_config_key(key)

    try:
        value = load_config().get(full_key)
    except KeyError:
        value = get_setting(full_key)

    typer.echo(_format_value(value))


@config_cli.command("set")
def config_set(key: str, value: str):
    """Store a mentipy configuration value."""

    set_setting(key, parse_config_value(value))


@config_cli.command("list")
def config_list():
    """List the built-in mentipy settings."""

    for key, value in sorted(list_settings().items()):
        typer.echo(f"{key} = {_format_value(value)}")


def main():
    """Run the mentipy CLI."""

    cli()
