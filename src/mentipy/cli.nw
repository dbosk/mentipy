The [[--results]] flag only changes the post-submit destination and the public
visibility of the HTML results page, so the CLI test can pin the wiring with a
simple spy.

<<test functions>>=
def test_serve_command_passes_public_results_flag(tmp_path, monkeypatch):
    runner = CliRunner()
    monkeypatch.setenv("MENTIPY_CONFIG", str(tmp_path / "config.json"))
    called = {}

    def fake_serve(store, host, port, public_results=False):
        called["path"] = store.path
        called["host"] = host
        called["port"] = port
        called["public_results"] = public_results

    monkeypatch.setattr("mentipy.cli.serve_http", fake_serve)

    result = runner.invoke(
        cli,
        ["serve", "--store", str(tmp_path / "answers.json"), "--results"],
    )

    assert result.exit_code == 0
    assert called["path"] == tmp_path / "answers.json"
    assert called["public_results"] is True
