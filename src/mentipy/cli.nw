The prefix resolver remains outside the renderer so [[view]], [[watch]], and
tests can pass already-fetched summaries when that avoids duplicate store
lookups.

<<functions>>=
def _render_results_snapshot(
    store: Store,
    prefix: str,
    *,
    console: Console | None = None,
):
    console = console or _result_console()
    full_hash = _resolve_full_hash(store, prefix)
    _render_results(store.results(full_hash), console=console)
@

The renderer tests need stored answers with stable timestamps.  These helpers
prepare the two cases that matter for terminal output: ordinary Markdown and a
fenced Python block.  The ANSI stripper is intentionally test-only; production
keeps the escape sequences so the terminal can display colours.

<<test functions>>=
def _store_with_markdown_answer(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(OpenQuestion("Comment?"))
    full_hash = store.resolve(prefix)
    store.record(full_hash, "**important** observation")

    data = store._data()
    data["answers"][full_hash][0]["ts"] = "2026-05-12T11:30:45Z"
    store._write(data)

    return store, prefix


def _store_with_code_answer(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(OpenQuestion("Comment?"))
    full_hash = store.resolve(prefix)
    store.record(full_hash, "```python\nprint('hello')\n```")

    data = store._data()
    data["answers"][full_hash][0]["ts"] = "2026-05-12T11:30:45Z"
    store._write(data)

    return store, prefix


def _without_ansi(text):
    return re.sub(r"\x1b\[[0-9;]*m", "", text)
