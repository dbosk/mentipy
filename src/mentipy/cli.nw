The public-serving branch still needs one helper of its own.  It reuses the
shared URL context above, rewrites remembered QR targets when the public URL
changes, and then hands control to the HTTP server.

<<functions>>=


def _serve_publicly(
    active_store: Store,
    chosen_host: str,
    chosen_port: int,
    *,
    public: PublicMode,
    results: bool,
):
    with _public_url_context(public, chosen_port) as public_url:
        configured_base = get_setting(BASE_URL_CONFIG)

        if public_url == configured_base:
            typer.echo(f"Public URL: {public_url}")
        else:
            count = regenerate_qrs(active_store, public_url)
            typer.echo(
                f"Public URL: {public_url}\n"
                f"Regenerated {count} QR codes; recompile your slides so "
                "they embed the new images."
            )

        serve_http(
            active_store,
            chosen_host,
            chosen_port,
            public_results=results,
        )
