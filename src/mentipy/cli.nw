def test_serve_command_public_without_value_defaults_to_upnp(
    tmp_path, monkeypatch
):
    runner = CliRunner()
    config_path = tmp_path / "config.json"
    monkeypatch.setenv("MENTIPY_CONFIG", str(config_path))
    called = {}
    state = {"closed": False}

    @contextmanager
    def fake_expose(mode, local_port, *, ssh_endpoint=None):
        called["mode"] = mode
        called["local_port"] = local_port
        called["ssh_endpoint"] = ssh_endpoint
        try:
            yield "http://public.example:8080"
        finally:
            state["closed"] = True

    def fake_serve(store, host, port, public_results=False):
        called["path"] = store.path
        called["host"] = host
        called["port"] = port
        called["public_results"] = public_results

    monkeypatch.setattr("mentipy.cli.expose", fake_expose)
    monkeypatch.setattr("mentipy.cli.regenerate_qrs", lambda _store, _base_url: 0)
    monkeypatch.setattr("mentipy.cli.serve_http", fake_serve)

    result = runner.invoke(
        cli,
        [
            "serve",
            "--public",
            "--port",
            "8080",
            "--store",
            str(tmp_path / "answers.json"),
        ],
        env={"MENTIPY_CONFIG": str(config_path)},
    )

    assert result.exit_code == 0
    assert called["mode"] is PublicMode.upnp
    assert called["local_port"] == 8080
    assert called["ssh_endpoint"] is None
    assert called["path"] == tmp_path / "answers.json"
    assert state["closed"] is True


