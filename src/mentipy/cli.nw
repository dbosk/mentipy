The interactive watcher test interrupts the sleep call after the first redraw so
the command remains a normal unit test.

<<test functions>>=
def test_watch_command_prints_a_snapshot(tmp_path, monkeypatch):
    runner = CliRunner()
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))
    full_hash = store.resolve(prefix)
    store.record(full_hash, 1)

    def stop_after_first_sleep(_interval):
        raise KeyboardInterrupt

    monkeypatch.setattr("mentipy.cli.time.sleep", stop_after_first_sleep)

    result = runner.invoke(
        cli,
        ["watch", prefix, "--store", str(store.path), "--interval", "0.01"],
    )

    assert result.exit_code == 0
    assert "Responses: 1" in result.stdout
    assert "B: 1" in result.stdout
