Posting an answer should redirect and persist exactly one response.

<<test functions>>=
def test_post_records_answers(live_server):
    store, prefix, port = live_server

    response, _body = _request(
        port,
        "POST",
        f"/{prefix}",
        body="value=1",
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )

    assert response.status == 303
    assert response.getheader("Location") == f"/{prefix}/thanks"
    full_hash = store.resolve(prefix)
    assert store.results(full_hash)["counts"] == [0, 1]
