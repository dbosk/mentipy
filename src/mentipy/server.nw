The helper functions collect the logic that would otherwise be repeated across
multiple routes.

<<functions>>=
def is_local_address(address: str) -> bool:
    """Return whether ``address`` is considered localhost."""

    return address in {"127.0.0.1", "::1", "::ffff:127.0.0.1"}


def _page(title: str, heading: str, body: str, *, refresh: bool = False) -> str:
    refresh_tag = ""
    if refresh:
        refresh_tag = (
            f'<meta http-equiv="refresh" content="{REFRESH_SECONDS}">'
        )

    return PAGE_TEMPLATE.substitute(
        title=escape(title),
        heading=escape(heading),
        refresh=refresh_tag,
        body=body,
    )


def _ambiguous_matches(store: Store, prefix: str) -> list[dict[str, Any]]:
    matches = []

    for full_hash in store.matches(prefix):
        meta = store.metadata(full_hash)
        matches.append(
            {
                "hash": full_hash,
                "url_prefix": meta["url_prefix"],
                "text": meta["text"],
            }
        )

    return matches


def _parse_answer(question, fields: dict[str, list[str]]) -> Any:
    if isinstance(question, MCQuestion):
        values = fields.get("value", [])
        if question.multi:
            return [int(value) for value in values]
        if len(values) != 1:
            raise ValueError("choose exactly one option")
        return int(values[0])

    if isinstance(question, OpenQuestion):
        value = fields.get("value", [""])[0]
        if len(value) > question.max_chars:
            raise ValueError("text answer too long")
        return value

    value = int(fields.get("value", [str(question.low)])[0])
    if value < question.low or value > question.high:
        raise ValueError("scale answer outside the allowed range")
    return value


def _render_index(store: Store) -> str:
    items = []

    for entry in store.all_questions():
        items.append(
            "<li>"
            f'<a href="/{entry["url_prefix"]}"><code>{entry["url_prefix"]}</code></a> '
            f'{escape(entry["text"])} '
            f'(<a href="/{entry["url_prefix"]}/results">results</a>)'
            "</li>"
        )

    if not items:
        return "<p>No questions have been registered yet.</p>"

    return "<ul>" + "".join(items) + "</ul>"


def _render_form(store: Store, full_hash: str) -> str:
    question = store.question(full_hash)
    prefix = store.metadata(full_hash)["url_prefix"]

    if isinstance(question, MCQuestion):
        input_type = "checkbox" if question.multi else "radio"
        inputs = "".join(
            f'<label><input type="{input_type}" name="value" value="{index}"> '
            f"{escape(option)}</label>"
            for index, option in enumerate(question.options)
        )
        return (
            f"<p>{escape(question.text)}</p>"
            f'<form method="post" action="/{prefix}">{inputs}'
            "<button type=\"submit\">Submit</button></form>"
        )

    if isinstance(question, OpenQuestion):
        return (
            f"<p>{escape(question.text)}</p>"
            f'<form method="post" action="/{prefix}">' 
            f'<textarea name="value" maxlength="{question.max_chars}"></textarea>'
            "<button type=\"submit\">Submit</button></form>"
        )

    inputs = "".join(
        f'<label><input type="radio" name="value" value="{value}"> '
        f"{value}</label>"
        for value in range(question.low, question.high + 1)
    )
    low_end_label = ""
    if question.low_label:
        low_end_label = f"<p>Low end: {escape(question.low_label)}</p>"
    high_end_label = ""
    if question.high_label:
        high_end_label = f"<p>High end: {escape(question.high_label)}</p>"

    return (
        f"<p>{escape(question.text)}</p>"
        + f'<form method="post" action="/{prefix}">'
        + low_end_label
        + inputs
        + high_end_label
        + "<button type=\"submit\">Submit</button></form>"
    )


def _render_results(store: Store, full_hash: str) -> str:
    results = store.results(full_hash)
    question = store.question(full_hash)
    lines = [f"<p>Total responses: <strong>{results['total']}</strong></p>"]

    if isinstance(question, MCQuestion):
        items = []
        for option, count in zip(question.options, results["counts"]):
            items.append(f"<li>{escape(option)}: {count}</li>")
        lines.append("<ul>" + "".join(items) + "</ul>")
        return "".join(lines)

    if isinstance(question, ScaleQuestion):
        items = []
        for value, count in results["counts"].items():
            items.append(f"<li>{value}: {count}</li>")
        lines.append("<ul>" + "".join(items) + "</ul>")
        return "".join(lines)

    if results["answers"]:
        items = []
        for answer in results["answers"]:
            items.append(
                f"<li><code>{escape(answer['ts'])}</code>: "
                f"{escape(answer['value'])}</li>"
            )
        lines.append("<ol>" + "".join(items) + "</ol>")
    else:
        lines.append("<p>No free-text answers yet.</p>")

    return "".join(lines)


def _json_results(store: Store, full_hash: str) -> str:
    return json.dumps(store.results(full_hash), ensure_ascii=False, indent=2)
