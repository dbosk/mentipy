        def to_svg(self):
            return (
                '<?xml version="1.0" encoding="UTF-8"?>\n'
                '<svg xmlns="http://www.w3.org/2000/svg">'
                '<text>packed</text></svg>'
            )

    class FakeModule:
        WordCloud = FakeWordCloud

    monkeypatch.setattr(
        server_module.importlib,
        "import_module",
        lambda _name: FakeModule,
    )

    rendered = server_module._render_wordcloud_svg(
        [("apple", 2), ("banana", 1)]
    )

    assert captured["frequencies"] == {"apple": 2, "banana": 1}
    assert captured["kwargs"]["mode"] == "RGBA"
    assert captured["kwargs"]["prefer_horizontal"] == 1.0
    assert captured["kwargs"]["random_state"] == 0
    assert rendered.startswith('<svg class="wordcloud-svg"')
    assert 'role="img"' in rendered
    assert '<?xml version="1.0"' not in rendered
@

\subsection{Sequence-navigation link}

The thanks page and the results page both want to offer a \enquote{Next
$\rightarrow$} link when the current question opts in.  The decision is
identical in shape (\enquote{is there a next question to point at, and does
this question opt out?}) but the link target depends on the caller --- the
thanks page always sends respondents to the next question's form so they can
answer, while the results page lands lecturers on the next question's results
page when they are driving from localhost and on the next form otherwise.
Centralising the decision in one helper keeps both call sites short and
prevents the two paths from drifting apart.

A missing or unknown next question, or [[question.next]] being false, returns
the empty string so a caller can unconditionally concatenate the result into
the page body.

<<functions>>=
def _render_next_link(
    store: Store, full_hash: str, *, results: bool = False
) -> str:
    question = store.question(full_hash)
    if not question.next:
        return ""
    next_hash = store.next_question(full_hash)
    if next_hash is None:
        return ""
    next_prefix = store.metadata(next_hash)["url_prefix"]
    suffix = "/results" if results else ""
    return (
        f'<p><a class="next-link" href="/{next_prefix}{suffix}">'
        f"Next →</a></p>"
    )
@

