The multipart parser must keep ordinary fields and uploaded file fields in the
same shape that URL-encoded parsing returns.  A single test with both field
kinds catches accidental divergence between the two request encodings.


<<test functions>>=
def test_parse_multipart_extracts_regular_and_file_fields():
    content_type, body = _multipart_form(
        [
            {"name": "value", "body": "run python solution.py"},
            {
                "name": "file",
                "filename": "solution.py",
                "body": "print('hi')\n",
            },
        ]
    )

    fields = server_module._parse_multipart(content_type, body)

    assert fields["value"] == ["run python solution.py"]
    assert fields["file"] == ["solution.py\nprint('hi')\n"]
