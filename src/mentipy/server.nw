The word-cloud results page has three render modes selected by the
author at slide time, so the tests run end-to-end for each mode.  The
visual modes now append the same frequency table used by the pure-table
mode, so the checks cover both the cloud markup and the exact-count
fallback.  We also send a payload containing markup characters because
the words flow straight into the HTML or SVG output --- a missing
[[html.escape]] would let respondents inject arbitrary markup.

<<test functions>>=
def test_results_page_wordcloud_svg_escapes_words_and_shows_frequencies(
    tmp_path, monkeypatch,
):
    monkeypatch.setattr(
        server_module.importlib,
        "import_module",
        lambda _name: (_ for _ in ()).throw(ImportError()),
    )
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(WordCloudQuestion("Words?", render="svg"))
    full_hash = store.resolve(prefix)
    store.record(full_hash, "<script>")
    store.record(full_hash, "linear")

    with _running_server(store) as port:
        _, body = _request(port, "GET", f"/{prefix}/results")

    assert "<svg" in body
