The results page replaces the old admin route, but it still stays local-only by
default so a live lecture does not accidentally expose intermediate tallies.

<<test functions>>=
def test_results_routes_stay_local_by_default(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))
    server = create_server(store, host="127.0.0.1", port=0)
    server.RequestHandlerClass._is_local = lambda self: False
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()

    try:
        response, body = _request(server.server_address[1], "GET", f"/{prefix}/results")
        assert response.status == 403
        assert "Results pages are only available on localhost." in body

        response, body = _request(
            server.server_address[1],
            "GET",
            f"/{prefix}/results.json",
        )
        assert response.status == 403
        assert "Result exports are only available on localhost." in body
    finally:
        server.shutdown()
        thread.join()
        server.server_close()
