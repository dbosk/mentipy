Ambiguous short prefixes should produce a Git-like [[300 Multiple Choices]] page
so the user can pick the intended poll.

<<test functions>>=
def test_ambiguous_prefix_returns_multiple_choices(tmp_path, monkeypatch):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    hashes = {
        "first": "abcd" + "1" * 60,
        "second": "abce" + "2" * 60,
    }

    monkeypatch.setattr(
        "mentipy.store.question_hash",
        lambda question: hashes[question.text],
    )

    first_prefix = store.register(OpenQuestion("first"))
    second_prefix = store.register(OpenQuestion("second"))
    server = create_server(store, host="127.0.0.1", port=0)
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()

    try:
        response, body = _request(server.server_address[1], "GET", "/abc")
    finally:
        server.shutdown()
        thread.join()
        server.server_close()

    assert response.status == 300
    assert first_prefix in body
    assert second_prefix in body
