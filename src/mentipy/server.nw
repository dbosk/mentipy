The custom server class only exists to enable threading and to keep worker
threads from blocking shutdown.

<<classes>>=
class ThreadingHTTPServer(ThreadingMixIn, HTTPServer):
    """A small threaded HTTP server for mentipy."""

    daemon_threads = True
@

The handler is generated from the store instance.  A closure is the simplest way
to make every request see the same persistence backend without resorting to
global state, and it lets the CLI decide whether the live results page should
stay local-only or be shown to respondents after they submit.

<<functions>>=
def _build_handler(store: Store, *, public_results: bool = False):
    class MentipyHandler(BaseHTTPRequestHandler):
        server_version = "mentipy/0.1"

        def log_message(self, *_args):
            return

        def _is_local(self) -> bool:
            return is_local_address(self.client_address[0])

        def _send(
            self,
            status: HTTPStatus,
            body: str,
            *,
            content_type: str = "text/html; charset=utf-8",
            headers: dict[str, str] | None = None,
        ):
            payload = body.encode("utf-8")
            self.send_response(status)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(payload)))
            if headers:
                for name, value in headers.items():
                    self.send_header(name, value)
            self.end_headers()
            self.wfile.write(payload)

        def _redirect(self, location: str):
            self.send_response(HTTPStatus.SEE_OTHER)
            self.send_header("Location", location)
            self.send_header("Content-Length", "0")
            self.end_headers()

        def _resolve(self, prefix: str) -> str | None:
            full_hash = store.resolve(prefix)
            if full_hash is not None:
                return full_hash

            matches = _ambiguous_matches(store, prefix)
            if len(matches) > 1:
                items = "".join(
                    "<li>"
                    f'<a href="/{candidate["url_prefix"]}"><code>{candidate["url_prefix"]}</code></a> '
                    f'{escape(candidate["text"])}'
                    "</li>"
                    for candidate in matches
                )
                self._send(
                    HTTPStatus.MULTIPLE_CHOICES,
                    _page(
                        "Ambiguous prefix",
                        "Ambiguous prefix",
                        f"<p>{escape(prefix)} matches multiple questions.</p>"
                        f"<ul>{items}</ul>",
                    ),
                )
                return None

            self._send(
                HTTPStatus.NOT_FOUND,
                _page(
                    "Unknown question",
                    "Unknown question",
                    f"<p>No question matches <code>{escape(prefix)}</code>.</p>",
                ),
            )
            return None

        def do_GET(self):
            parsed = urlparse(self.path)
            path = parsed.path

            if path == "/static/style.css":
                self._send(
                    HTTPStatus.OK,
                    STYLE_CSS,
                    content_type="text/css; charset=utf-8",
                )
                return

            if path == "/":
                if not self._is_local():
                    self._send(
                        HTTPStatus.FORBIDDEN,
                        _page(
                            "Forbidden",
                            "Forbidden",
                            "<p>The question index is only available on localhost.</p>",
                        ),
                    )
                    return

                self._send(
                    HTTPStatus.OK,
                    _page("Questions", "Questions", _render_index(store)),
                )
                return

            segments = [segment for segment in path.split("/") if segment]
            if not segments:
                self.send_error(HTTPStatus.NOT_FOUND)
                return

            self._handle_question_get(segments)

        def _handle_question_get(self, segments: list[str]):
            if len(segments) == 2 and segments[1] == "thanks":
                full_hash = self._resolve(segments[0])
                if full_hash is None:
                    return
                title = store.metadata(full_hash)["text"]
                self._send(
                    HTTPStatus.OK,
                    _page(
                        "Thanks",
                        title,
                        "<p>Thanks, your answer was recorded.</p>",
                    ),
                )
                return

            if len(segments) == 2 and segments[1] == "results":
                if not public_results and not self._is_local():
                    self._send(
                        HTTPStatus.FORBIDDEN,
                        _page(
                            "Forbidden",
                            "Forbidden",
                            "<p>Results pages are only available on localhost.</p>",
                        ),
                    )
                    return

                full_hash = self._resolve(segments[0])
                if full_hash is None:
                    return

                title = store.metadata(full_hash)["text"]
                self._send(
                    HTTPStatus.OK,
                    _page(
                        f"Results for {title}",
                        title,
                        _render_results(store, full_hash),
                        refresh=True,
                    ),
                )
                return

            if len(segments) == 2 and segments[1] == "results.json":
                if not self._is_local():
                    self._send(
                        HTTPStatus.FORBIDDEN,
                        _page(
                            "Forbidden",
                            "Forbidden",
                            "<p>Result exports are only available on localhost.</p>",
                        ),
                    )
                    return

                full_hash = self._resolve(segments[0])
                if full_hash is None:
                    return

                self._send(
                    HTTPStatus.OK,
                    _json_results(store, full_hash),
                    content_type="application/json; charset=utf-8",
                )
                return

            if len(segments) != 1:
                self.send_error(HTTPStatus.NOT_FOUND)
                return

            full_hash = self._resolve(segments[0])
            if full_hash is None:
                return

            title = store.metadata(full_hash)["text"]
            self._send(
                HTTPStatus.OK,
                _page(title, title, _render_form(store, full_hash)),
            )

        def do_POST(self):
            parsed = urlparse(self.path)
            segments = [segment for segment in parsed.path.split("/") if segment]
            if len(segments) != 1:
                self.send_error(HTTPStatus.NOT_FOUND)
                return

            full_hash = self._resolve(segments[0])
            if full_hash is None:
                return

            length = int(self.headers.get("Content-Length", "0"))
            body = self.rfile.read(length).decode("utf-8")
            fields = parse_qs(body, keep_blank_values=True)
            question = store.question(full_hash)

            try:
                value = _parse_answer(question, fields)
            except (TypeError, ValueError) as err:
                self._send(
                    HTTPStatus.BAD_REQUEST,
                    _page(
                        "Invalid answer",
                        "Invalid answer",
                        f"<p>{escape(str(err))}</p>",
                    ),
                )
                return

            store.record(full_hash, value)
            prefix = store.metadata(full_hash)["url_prefix"]
            if public_results:
                self._redirect(f"/{prefix}/results")
                return
            self._redirect(f"/{prefix}/thanks")

    return MentipyHandler


def create_server(
    store: Store,
    host: str = "0.0.0.0",
    port: int = 8080,
    *,
    public_results: bool = False,
) -> ThreadingHTTPServer:
    """Return a configured mentipy HTTP server."""

    return ThreadingHTTPServer(
        (host, port),
        _build_handler(store, public_results=public_results),
    )


def serve(
    store: Store,
    host: str = "0.0.0.0",
    port: int = 8080,
    *,
    public_results: bool = False,
):
    """Run the mentipy HTTP server until interrupted."""

    server = create_server(store, host, port, public_results=public_results)
    try:
        server.serve_forever()
    finally:
        server.server_close()
