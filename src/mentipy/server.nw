def is_local_address(address: str) -> bool:
    """Return whether ``address`` is considered localhost."""

    return address in {"127.0.0.1", "::1", "::ffff:127.0.0.1"}


def _page(title: str, heading: str, body: str, *, refresh: bool = False) -> str:
    refresh_tag = ""
    if refresh:
        refresh_tag = (
            f'<meta http-equiv="refresh" content="{REFRESH_SECONDS}">'
        )

    return PAGE_TEMPLATE.substitute(
        title=escape(title),
        heading=escape(heading),
        refresh=refresh_tag,
        body=body,
    )


def _ambiguous_matches(store: Store, prefix: str) -> list[dict[str, Any]]:
    matches = []

    for full_hash in store.matches(prefix):
        meta = store.metadata(full_hash)
        matches.append(
            {
                "hash": full_hash,
                "url_prefix": meta["url_prefix"],
                "text": meta["text"],
            }
        )

    return matches
