<<test functions>>=
def test_handler_marks_non_local_admin_clients_as_remote(tmp_path):
    handler_class = server_module._build_handler(Store(tmp_path / "mentipy.json"))
    handler = handler_class.__new__(handler_class)
    handler.client_address = ("10.0.0.5", 1234)

    assert handler._is_local() is False
    assert is_local_address("127.0.0.1") is True
