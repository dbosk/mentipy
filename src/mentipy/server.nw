\subsection{Per-type stats lines}

Multiple-choice questions get a mode callout: which option the class
landed on most.  Scale questions get the descriptive statistics inline
in one row.  Open questions get the average answer length.  Each helper
returns an empty string when there are no answers, so the page degrades
gracefully to just the window filter and the \enquote{Total responses:
0} line.

<<functions>>=
def _render_mc_stats(
    question: MCQuestion, summary: dict[str, Any]
) -> str:
    mode_index = summary.get("mode_index")
    if mode_index is None:
        return ""
    label = question.options[mode_index]
    percentage = summary["percentages"][mode_index]
    return (
        f'<p class="mode-callout">'
        f'Mode: <strong>{escape(label)}</strong> '
        f'({percentage:.0f}%)'
        f'</p>'
    )
@

<<functions>>=
def _render_scale_stats(summary: dict[str, Any]) -> str:
    if summary.get("mean") is None:
        return ""
    pairs = [
        ("Mean", f'{summary["mean"]:.2f}'),
        ("Median", f'{summary["median"]}'),
        ("Std", f'{summary["stddev"]:.2f}'),
        ("Min", f'{summary["min"]}'),
        ("Max", f'{summary["max"]}'),
    ]
    body = " · ".join(
        f'<span class="stat-label">{label}:</span> '
        f'<strong>{value}</strong>'
        for label, value in pairs
    )
    return f'<p class="stats">{body}</p>'
@

<<functions>>=
def _render_open_stats(summary: dict[str, Any]) -> str:
    avg = summary.get("avg_length")
    if avg is None:
        return ""
    return (
        f'<p class="stats">'
        f'<span class="stat-label">Avg length:</span> '
        f'<strong>{avg:.0f}</strong> chars'
        f'</p>'
    )
