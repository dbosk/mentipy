The optional public-results mode is deliberately narrower: it redirects
respondents to the live tally and opens that HTML page outside localhost,
while the JSON export remains a local presenter tool.

<<test functions>>=
def test_public_results_mode_redirects_to_results_and_allows_remote_view(
    tmp_path,
):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))
    server = create_server(
        store,
        host="127.0.0.1",
        port=0,
        public_results=True,
    )
    server.RequestHandlerClass._is_local = lambda self: False
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()

    try:
        response, _body = _request(
            server.server_address[1],
            "POST",
            f"/{prefix}",
            body="value=1",
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )

        assert response.status == 303
        assert response.getheader("Location") == f"/{prefix}/results"

        response, body = _request(server.server_address[1], "GET", f"/{prefix}/results")
        assert response.status == 200
        assert "Total responses" in body

        response, body = _request(
            server.server_address[1],
            "GET",
            f"/{prefix}/results.json",
        )
        assert response.status == 403
        assert "Result exports are only available on localhost." in body
    finally:
        server.shutdown()
        thread.join()
        server.server_close()
