The scale form should place its human-readable anchors around the numbered
options so the low end appears above the list and the high end below it.

<<test functions>>=
def test_scale_form_places_endpoints_around_the_scale(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(
        ScaleQuestion(
            "How fast is today's pace?",
            low=1,
            high=5,
            low_label="Too slow",
            high_label="Too fast",
        )
    )
    full_hash = store.resolve(prefix)

    assert full_hash is not None

    rendered = server_module._render_form(store, full_hash)

    low_pos = rendered.index("Low end: Too slow")
    first_option_pos = rendered.index('value="1"')
    last_option_pos = rendered.index('value="5"')
    high_pos = rendered.index("High end: Too fast")

    assert low_pos < first_option_pos < last_option_pos < high_pos
