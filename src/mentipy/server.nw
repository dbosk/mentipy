\subsection{Counts as a horizontal bar chart}

The histogram is one CSS-only bar per category.  Each row carries the
label, a track that fills proportionally to the count, and the count
itself with its share as a percentage.  Inline [[width:]] styles avoid
inventing a JavaScript charting layer for what is fundamentally a
single linear scale.

<<functions>>=
def _render_bar_chart(
    labels: list[str],
    counts: list[int],
    percentages: list[float],
) -> str:
    rows = []
    for label, count, percentage in zip(labels, counts, percentages):
        rows.append(
            f'<div class="bar-row">'
            f'<span class="bar-label">{escape(str(label))}</span>'
            f'<span class="bar-bar">'
            f'<span class="bar-fill" '
            f'style="width:{percentage:.1f}%"></span>'
            f'</span>'
            f'<span class="bar-count">{count} '
            f'({percentage:.0f}%)</span>'
            f'</div>'
        )
    return '<div class="bar-chart">' + "".join(rows) + '</div>'
@

<<test functions>>=
def test_bar_chart_emits_one_row_per_label_with_inline_width():
    rendered = server_module._render_bar_chart(
