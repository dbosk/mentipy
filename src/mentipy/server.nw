<<test functions>>=
def _multipart_form(parts, *, boundary="Boundary42"):
    chunks = []

    for part in parts:
        chunks.append(f"--{boundary}\r\n".encode("ascii"))
        disposition = (
            f'Content-Disposition: form-data; name="{part["name"]}"'
        )
        if "filename" in part:
            disposition += f'; filename="{part["filename"]}"'
        chunks.append(disposition.encode("utf-8") + b"\r\n")
        if "content_type" in part:
            chunks.append(
                f'Content-Type: {part["content_type"]}'.encode("utf-8")
                + b"\r\n"
            )
        chunks.append(b"\r\n")
        payload = part["body"]
        if isinstance(payload, str):
            payload = payload.encode(part.get("encoding", "utf-8"))
        chunks.append(payload)
        chunks.append(b"\r\n")

    chunks.append(f"--{boundary}--\r\n".encode("ascii"))
    return (
        f"multipart/form-data; boundary={boundary}",
        b"".join(chunks),
    )
