The route test covers the request/response surface the presenter actually uses.

<<test functions>>=
def test_server_routes_return_expected_status_codes(live_server):
    store, prefix, port = live_server

    response, body = _request(port, "GET", "/")
    assert response.status == 200
    assert prefix in body

    response, body = _request(port, "GET", f"/{prefix}")
    assert response.status == 200
    assert "Pick one" in body

    response, _body = _request(port, "GET", "/static/style.css")
    assert response.status == 200

    response, body = _request(port, "GET", f"/{prefix}/thanks")
    assert response.status == 200
    assert "recorded" in body

    response, body = _request(port, "GET", f"/{prefix}/results")
    assert response.status == 200
    assert "Total responses" in body

    response, body = _request(port, "GET", f"/{prefix}/results.json")
    assert response.status == 200
    assert json.loads(body)["url_prefix"] == prefix
