def test_results_page_includes_window_filter_form(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))

    with _running_server(store) as port:
        response, body = _request(
            port, "GET", f"/{prefix}/results"
        )

    assert response.status == 200
    assert 'name="window"' in body
    assert 'value="hour"' in body
    assert 'value="day"' in body
    assert 'value="all"' in body
    assert 'value="all" selected' in body


def test_results_page_window_query_filters_recent_only(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))
    full_hash = store.resolve(prefix)
    store.record(full_hash, 0)
    store.record(full_hash, 1)

    data = store._data()
    aged = (
        datetime.now(timezone.utc) - timedelta(hours=2)
    ).isoformat().replace("+00:00", "Z")
    data["answers"][full_hash][0]["ts"] = aged
    store._write(data)

    with _running_server(store) as port:
        _, last_hour = _request(
            port, "GET", f"/{prefix}/results?window=hour"
        )
        _, all_time = _request(
            port, "GET", f"/{prefix}/results?window=all"
        )

    assert "Total responses: <strong>1</strong>" in last_hour
    assert "Total responses: <strong>2</strong>" in all_time
    assert 'value="hour" selected' in last_hour
    assert 'value="all" selected' in all_time
