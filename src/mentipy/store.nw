The formatter should use the process-local time zone.  The test fixes the
process time zone to a UTC+2 rule so the expected clock time is independent of
where the test machine happens to run.

<<test functions>>=
def test_format_timestamp_uses_local_time(monkeypatch):
    if not hasattr(time, "tzset"):
        pytest.skip("tzset is unavailable on this platform")

    original_tz = os.environ.get("TZ")
    monkeypatch.setenv("TZ", "UTC-2")
    time.tzset()

    try:
        assert format_timestamp("2026-05-12T11:30:45Z") == "2026-05-12 13:30"
    finally:
        if original_tz is None:
            monkeypatch.delenv("TZ", raising=False)
        else:
            monkeypatch.setenv("TZ", original_tz)
        time.tzset()
