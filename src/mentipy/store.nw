def test_register_is_idempotent(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    question = OpenQuestion("One thing to change?")

    first = store.register(question)
    second = store.register(question)

    assert first == second


def test_register_uses_shortest_available_prefix(tmp_path, monkeypatch):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    hashes = {
        "first": "abcd" + "1" * 60,
        "second": "dcba" + "2" * 60,
    }

    monkeypatch.setattr(
        "mentipy.store.question_hash",
        lambda question: hashes[question.text],
    )

    first = store.register(OpenQuestion("first"))
    second = store.register(OpenQuestion("second"))

    assert first == "abcd"
    assert second == "dcba"


def test_register_extends_only_the_newer_prefix(tmp_path, monkeypatch):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    hashes = {
        "first": "abcd1" + "0" * 59,
        "second": "abcd2" + "0" * 59,
    }

    monkeypatch.setattr(
        "mentipy.store.question_hash",
        lambda question: hashes[question.text],
    )

    first = store.register(OpenQuestion("first"))
    second = store.register(OpenQuestion("second"))

    assert first == "abcd"
