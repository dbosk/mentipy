Resolution prefers an exact issued prefix, because that is what keeps an old QR
code valid after a newer question collides on the same early hash characters.
When there is no such exact reservation, we fall back to Git-style unique full
hash prefixes.

<<store methods>>=
def matches(self, prefix: str) -> list[str]:
    """Return all stored hashes that start with ``prefix``."""

    data = self._data()
    return sorted(
        full_hash for full_hash in data["questions"] if full_hash.startswith(prefix)
    )


def resolve(self, prefix: str) -> str | None:
    """Return the full hash addressed by ``prefix``, if it is unambiguous."""

    data = self._data()

    for full_hash, meta in data["questions"].items():
        if meta["url_prefix"] == prefix:
            return full_hash

    matches = [
        full_hash for full_hash in data["questions"] if full_hash.startswith(prefix)
    ]
    return matches[0] if len(matches) == 1 else None
@

The resolver tests exercise all three interesting cases: exact issued prefix,
unique longer prefix, and a genuinely ambiguous short prefix.

<<test functions>>=
def test_resolve_accepts_exact_and_unique_prefixes(tmp_path, monkeypatch):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    hashes = {
        "first": "abcd1" + "0" * 59,
        "second": "abcd2" + "0" * 59,
    }

    monkeypatch.setattr(
        "mentipy.store.question_hash",
        lambda question: hashes[question.text],
    )

    first_prefix = store.register(OpenQuestion("first"))
    second_prefix = store.register(OpenQuestion("second"))

    assert store.resolve(first_prefix) == hashes["first"]
    assert store.resolve(second_prefix) == hashes["second"]
    assert store.resolve("abcd20") == hashes["second"]
    assert store.resolve("abc") is None
    assert store.resolve("ffff") is None
@

The HTTP server needs cheap read helpers for rendering pages and the CLI needs a
stable listing for index-like views.

<<store methods>>=
def metadata(self, full_hash: str) -> dict[str, Any]:
    """Return the stored metadata for ``full_hash``."""

    return dict(self._data()["questions"][full_hash])


def question(self, full_hash: str) -> Question:
    """Return the typed question for ``full_hash``."""

    return question_from_dict(self.metadata(full_hash))


def all_questions(self) -> list[dict[str, Any]]:
    """Return all registered questions, ordered by issued prefix."""

    data = self._data()
    rows = []

    for full_hash, meta in sorted(
        data["questions"].items(),
        key=lambda item: item[1]["url_prefix"],
    ):
        row = dict(meta)
        row["hash"] = full_hash
        rows.append(row)

    return rows
@

Answer recording is the only mutating operation after registration, so it is
where the atomic rewrite matters most.

<<store methods>>=
def record(self, full_hash: str, value: Any):
    """Append ``value`` as a recorded answer to ``full_hash``."""

    with self._lock:
        data = self._data()

        if full_hash not in data["questions"]:
            raise KeyError(full_hash)

        answers = data["answers"].setdefault(full_hash, [])
        answers.append({"ts": _timestamp(), "value": value})
        self._write(data)
@

We test atomicity by forcing [[os.replace]] to fail after the temporary file has
been written.  The original JSON file must remain intact.  We also test the
lock by recording from two threads through the same store instance.

<<test functions>>=
def test_record_leaves_the_original_file_intact_on_failed_replace(
    tmp_path, monkeypatch
):
    path = tmp_path / "mentipy.json"
    store = Store(path, min_prefix=4)
    prefix = store.register(OpenQuestion("Comment?"))
    full_hash = store.resolve(prefix)
    before = path.read_text(encoding="utf-8")

    def fail_replace(_source, _target):
        raise RuntimeError("replace failed")

    monkeypatch.setattr("mentipy.store.os.replace", fail_replace)

    with pytest.raises(RuntimeError):
        store.record(full_hash, "hello")

    assert path.read_text(encoding="utf-8") == before


def test_record_keeps_answers_from_concurrent_threads(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))
    full_hash = store.resolve(prefix)
    start = threading.Barrier(3)

    def worker(value):
        start.wait()
        store.record(full_hash, value)

    first = threading.Thread(target=worker, args=(0,))
    second = threading.Thread(target=worker, args=(1,))
    first.start()
    second.start()
    start.wait()
    first.join()
    second.join()

    answers = store.results(full_hash)["answers"]

    assert len(answers) == 2
    assert sorted(answer["value"] for answer in answers) == [0, 1]
@

Finally, the result view aggregates answers according to the question type.  We
keep the raw answer log in the returned structure because the CLI export command
and the admin JSON endpoint both need it.

<<store methods>>=
def results(self, full_hash: str) -> dict[str, Any]:
    """Return aggregated results for ``full_hash``."""

    data = self._data()
    meta = data["questions"][full_hash]
    question = question_from_dict(meta)
    answers = list(data["answers"].get(full_hash, []))
    results = {
        "hash": full_hash,
        "url_prefix": meta["url_prefix"],
        "question": question.to_dict(),
        "total": len(answers),
        "answers": answers,
    }

    if isinstance(question, MCQuestion):
        counts = [0] * len(question.options)
        for answer in answers:
            values = answer["value"] if question.multi else [answer["value"]]
            for index in values:
                if 0 <= index < len(counts):
                    counts[index] += 1
        results["counts"] = counts
        return results

    if isinstance(question, ScaleQuestion):
        counts = {
            value: 0 for value in range(question.low, question.high + 1)
        }
        for answer in answers:
            value = answer["value"]
            if value in counts:
                counts[value] += 1
        results["counts"] = counts

    return results
@

The aggregation test keeps the counting contract explicit for the dashboard and
the watcher.

<<test functions>>=
def test_results_aggregate_multiple_choice_answers(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B", "C")))
    full_hash = store.resolve(prefix)
    store.record(full_hash, 0)
    store.record(full_hash, 2)
    store.record(full_hash, 2)

    results = store.results(full_hash)

    assert results["counts"] == [1, 0, 2]
    assert results["total"] == 3
