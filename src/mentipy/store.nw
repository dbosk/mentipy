)
def test_record_rejects_answers_that_do_not_match_the_question(
    tmp_path, question, value
):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(question)
    full_hash = store.resolve(prefix)

    with pytest.raises((TypeError, ValueError)):
        store.record(full_hash, value)

    assert store.results(full_hash)["total"] == 0


def test_record_requires_non_empty_unique_multi_select_answers(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick", ("A", "B"), multi=True))
    full_hash = store.resolve(prefix)

    with pytest.raises(ValueError):
        store.record(full_hash, [])
    with pytest.raises(ValueError):
        store.record(full_hash, [0, 0])

    assert store.results(full_hash)["total"] == 0


def test_record_normalizes_multi_select_tuples_to_lists(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick", ("A", "B", "C"), multi=True))
    full_hash = store.resolve(prefix)

    store.record(full_hash, (0, 2))

    assert store.results(full_hash)["answers"][0]["value"] == [0, 2]
@

The result view aggregates answers according to the question type, but it
also has to support two cross-cutting concerns the lecturer expects from a
classroom poll.
\begin{description}
\item[Time-window filtering] A question reused across lectures, or even
  across years, accumulates every answer it has ever received under the
  same canonical hash.  The lecturer wants to see \emph{just this hour}
  or \emph{just today} as easily as the lifetime view, without that
  pooling becoming an obstacle.
\item[Descriptive statistics] Counts alone do not tell a lecturer whether
  the class agrees, splits, or drifts; means and standard deviations make
  scale results actionable, and a mode callout makes multiple-choice
  results readable at a glance.
\end{description}
Both concerns are read-side filters and computations over the same answer
log---no schema change is needed because every answer already carries a
UTC timestamp.  We keep the (filtered) raw log in the returned structure
because the CLI export and the JSON results endpoint still need it;
aggregated counts and statistics ride on top so HTML, JSON, and CLI
consumers all read the same numbers.

<<constants>>=
RESULTS_WINDOW_DELTAS = {
    "hour": timedelta(hours=1),
    "day": timedelta(days=1),
    "all": None,
}
