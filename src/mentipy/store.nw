<<test functions>>=
def test_setting_helpers_use_the_mentipy_namespace(tmp_path, monkeypatch):
    monkeypatch.setenv("MENTIPY_CONFIG", str(tmp_path / "config.json"))

    set_setting("port", 9000)

    assert get_setting("mentipy.port") == 9000
    assert list_settings()["port"] == 9000
