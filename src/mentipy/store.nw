Registration needs two properties.  It must be idempotent for the same content,
and it must keep old printed URLs stable even when a later question shares the
same beginning of the hash.  We achieve that by treating issued prefixes as
exact reservations and extending only the newer question.

<<store methods>>=
def register(self, question: Question) -> str:
    """Register ``question`` and return its stable URL prefix."""

    with self._lock:
        data = self._data()
        full_hash = question_hash(question)

        if full_hash in data["questions"]:
            return data["questions"][full_hash]["url_prefix"]

        prefix = self._allocate_prefix(full_hash, data["questions"])
        entry = question.to_dict()
        entry["url_prefix"] = prefix
        data["questions"][full_hash] = entry
        data["answers"].setdefault(full_hash, [])
        self._write(data)
        return prefix


def _allocate_prefix(
    self, full_hash: str, questions: dict[str, dict[str, Any]]
) -> str:
    issued = {meta["url_prefix"] for meta in questions.values()}

    for size in range(self.min_prefix, len(full_hash) + 1):
        candidate = full_hash[:size]
        matches = [hash_ for hash_ in questions if hash_.startswith(candidate)]
        if not matches and candidate not in issued:
            return candidate

    raise RuntimeError("could not allocate a unique URL prefix")
