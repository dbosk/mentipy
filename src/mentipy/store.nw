    prefix = store.register(MCQuestion("Pick one", ("A", "B", "C")))
    full_hash = store.resolve(prefix)
    store.record(full_hash, 0)
    store.record(full_hash, 0)
    store.record(full_hash, 0)
    store.record(full_hash, 2)

    summary = store.results(full_hash)

    assert summary["counts"] == [3, 0, 1]
    assert summary["mode_index"] == 0
    assert summary["percentages"][0] == pytest.approx(75.0)
    assert summary["percentages"][1] == pytest.approx(0.0)
    assert summary["percentages"][2] == pytest.approx(25.0)
