def test_results_aggregate_wordcloud_answers(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(WordCloudQuestion("Words?"))
    full_hash = store.resolve(prefix)
    store.record(full_hash, "apple banana")
    store.record(full_hash, "Apple cherry")

    summary = store.results(full_hash)

    assert summary["frequencies"] == [
        ["apple", 2],
        ["banana", 1],
        ["cherry", 1],
    ]
    assert summary["unique_words"] == 3
    assert summary["total_tokens"] == 4
