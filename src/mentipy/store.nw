The window filter is the cross-cutting concern, so we test it
independently of question type.  We backdate one of the answers by
editing the on-disk store directly: monkeypatching [[_timestamp]] would
only affect future writes, not the existing log entry we want to age.

<<test functions>>=
def test_results_window_filter_keeps_only_recent_answers(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))
    full_hash = store.resolve(prefix)
    store.record(full_hash, 0)
    store.record(full_hash, 1)

    data = store._data()
    aged = datetime.now(timezone.utc) - timedelta(hours=2)
    data["answers"][full_hash][0]["ts"] = (
        aged.isoformat().replace("+00:00", "Z")
    )
    store._write(data)

    last_hour = store.results(full_hash, window="hour")
    all_time = store.results(full_hash, window="all")

    assert last_hour["total"] == 1
    assert all_time["total"] == 2
    assert last_hour["window"] == "hour"
    assert all_time["window"] == "all"


def test_results_window_unknown_falls_back_to_all(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(MCQuestion("Pick one", ("A", "B")))
    full_hash = store.resolve(prefix)
    store.record(full_hash, 0)

    garbled = store.results(full_hash, window="garbage")

    assert garbled["window"] == "all"
    assert garbled["total"] == 1
