def test_record_rejects_invalid_pin_answers(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    question = PinTextQuestion("Pin the bug", "total =+ x")
    full_hash = store.resolve(store.register(question))

    with pytest.raises(ValueError, match="at least one"):
        store.record(full_hash, [])
    with pytest.raises(ValueError, match="more pins"):
