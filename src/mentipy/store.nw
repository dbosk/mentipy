Resolution prefers an exact issued prefix, because that is what keeps an old QR
code valid after a newer question collides on the same early hash characters.
When there is no such exact reservation, we fall back to Git-style unique full
hash prefixes.

<<store methods>>=
def matches(self, prefix: str) -> list[str]:
    """Return all stored hashes that start with ``prefix``."""

    data = self._data()
    return sorted(
        full_hash for full_hash in data["questions"] if full_hash.startswith(prefix)
    )


def resolve(self, prefix: str) -> str | None:
    """Return the full hash addressed by ``prefix``, if it is unambiguous."""

    data = self._data()

    for full_hash, meta in data["questions"].items():
        if meta["url_prefix"] == prefix:
            return full_hash

    matches = [
        full_hash for full_hash in data["questions"] if full_hash.startswith(prefix)
    ]
    return matches[0] if len(matches) == 1 else None
@

The resolver tests exercise all three interesting cases: exact issued prefix,
unique longer prefix, and a genuinely ambiguous short prefix.

<<test functions>>=
def test_resolve_accepts_exact_and_unique_prefixes(tmp_path, monkeypatch):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    hashes = {
        "first": "abcd1" + "0" * 59,
        "second": "abcd2" + "0" * 59,
    }

    monkeypatch.setattr(
        "mentipy.store.question_hash",
        lambda question: hashes[question.text],
    )

    first_prefix = store.register(OpenQuestion("first"))
    second_prefix = store.register(OpenQuestion("second"))

    assert store.resolve(first_prefix) == hashes["first"]
    assert store.resolve(second_prefix) == hashes["second"]
    assert store.resolve("abcd20") == hashes["second"]
    assert store.resolve("abc") is None
    assert store.resolve("ffff") is None
@

The HTTP server needs cheap read helpers for rendering pages and the CLI needs a
stable listing for index-like views.

<<store methods>>=
def metadata(self, full_hash: str) -> dict[str, Any]:
    """Return the stored metadata for ``full_hash``."""

    return dict(self._data()["questions"][full_hash])


def question(self, full_hash: str) -> Question:
    """Return the typed question for ``full_hash``."""

    return question_from_dict(self.metadata(full_hash))


def all_questions(self) -> list[dict[str, Any]]:
    """Return all registered questions, ordered by issued prefix."""

    data = self._data()
    rows = []

    for full_hash, meta in sorted(
        data["questions"].items(),
        key=lambda item: item[1]["url_prefix"],
    ):
        row = dict(meta)
        row["hash"] = full_hash
        rows.append(row)

    return rows


def iter_prefixes(self) -> Iterator[str]:
    """Yield the URL prefix of every registered question."""

    with self._lock:
        data = self._data()

    for meta in data["questions"].values():
        yield meta["url_prefix"]
@

Answer recording is the only mutating operation after registration, so it is
where the atomic rewrite matters most.  It is also the last write boundary
shared by the HTTP server and any direct library caller.  Later readers assume
the stored value already matches the registered question type, so
[[Store.record()]] validates and normalises answers before it appends them.

The validation rules mirror the question types.  Single-choice and scale
answers are bounded integers, multi-select answers are non-empty collections of
unique indices, and open-text answers are strings within the configured limit.
We normalise multi-select sequences to plain lists so the JSON shape on disk is
stable no matter whether a caller passed a list or a tuple.

<<functions>>=
def _normalize_recorded_answer(question: Question, value: Any) -> Any:
    if isinstance(question, MCQuestion):
        if question.multi:
            if not isinstance(value, (list, tuple)):
                raise TypeError(
                    "multi-select answers must be stored as a list or tuple"
                )
            if not value:
                raise ValueError("choose at least one option")

            indices = []
            seen = set()
            for index in value:
                if type(index) is not int:
                    raise TypeError(
                        "multiple-choice answer indices must be integers"
                    )
                if index < 0 or index >= len(question.options):
                    raise ValueError(
                        "multiple-choice answer outside the allowed range"
                    )
                if index in seen:
                    raise ValueError(
                        "multiple-choice answer repeats the same option"
                    )
                seen.add(index)
                indices.append(index)

            return indices

        if type(value) is not int:
            raise TypeError(
                "single-choice answers must be stored as an integer option index"
            )
        if value < 0 or value >= len(question.options):
            raise ValueError("multiple-choice answer outside the allowed range")
        return value

    if isinstance(question, ScaleQuestion):
        if type(value) is not int:
            raise TypeError("scale answers must be stored as integers")
        if value < question.low or value > question.high:
            raise ValueError("scale answer outside the allowed range")
        return value

    if not isinstance(value, str):
        raise TypeError("open-text answers must be stored as strings")
    if len(value) > question.max_chars:
        raise ValueError("open-text answer exceeds the question limit")
    return value
@

<<store methods>>=
def record(self, full_hash: str, value: Any):
    """Append a validated answer to ``full_hash``."""

    with self._lock:
        data = self._data()

        if full_hash not in data["questions"]:
            raise KeyError(full_hash)

        question = question_from_dict(data["questions"][full_hash])
        normalized = _normalize_recorded_answer(question, value)
        answers = data["answers"].setdefault(full_hash, [])
        answers.append({"ts": _timestamp(), "value": normalized})
        self._write(data)
