When the window filter empties the answer log, every per-type statistic
collapses to [[None]] so consumers can render an explicit \enquote{no
answers yet} state without having to distinguish a missing field from a
genuine zero.

<<test functions>>=
def test_results_empty_window_collapses_stats_to_none(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    scale_prefix = store.register(
        ScaleQuestion("How clear?", low=1, high=5)
    )
    open_prefix = store.register(OpenQuestion("Comment?"))
    mc_prefix = store.register(MCQuestion("Pick one", ("A", "B")))

    scale = store.results(store.resolve(scale_prefix), window="hour")
    opened = store.results(store.resolve(open_prefix), window="hour")
    mc = store.results(store.resolve(mc_prefix), window="hour")

    assert scale["total"] == 0
    assert scale["mean"] is None
    assert scale["median"] is None
    assert scale["stddev"] is None
    assert scale["min"] is None
    assert scale["max"] is None

    assert opened["total"] == 0
    assert opened["avg_length"] is None

    assert mc["total"] == 0
    assert mc["mode_index"] is None
