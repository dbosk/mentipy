For scale questions, the descriptive statistics must agree with the
[[statistics]] module so that any future change of dispersion measure is
deliberate and visible in the diff.

<<test functions>>=
def test_results_scale_reports_descriptive_statistics(tmp_path):
    store = Store(tmp_path / "mentipy.json", min_prefix=4)
    prefix = store.register(ScaleQuestion("How clear?", low=1, high=5))
    full_hash = store.resolve(prefix)
    for value in [1, 2, 2, 3, 5]:
        store.record(full_hash, value)

    summary = store.results(full_hash)

    assert summary["mean"] == pytest.approx(2.6)
    assert summary["median"] == 2
    assert summary["stddev"] == pytest.approx(
        statistics.pstdev([1, 2, 2, 3, 5])
    )
    assert summary["min"] == 1
    assert summary["max"] == 5
