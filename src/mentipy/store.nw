The configuration keys live here because both the LaTeX integration and the CLI
need the same defaults, and they must agree even when the package is imported
outside the [[mentipy]] command.  We therefore compute the config file path from
the fixed application name, not from [[sys.argv[0]]].

<<constants>>=
CONFIG_NAMESPACE = "mentipy"

BASE_URL_CONFIG = "mentipy.base_url"
HOST_CONFIG = "mentipy.host"
PORT_CONFIG = "mentipy.port"
STORE_CONFIG = "mentipy.store"
QR_DIR_CONFIG = "mentipy.qr_dir"
QR_FORMAT_CONFIG = "mentipy.qr_format"
MIN_PREFIX_CONFIG = "mentipy.min_prefix"

DEFAULT_BASE_URL = "http://localhost:8080"
DEFAULT_HOST = "0.0.0.0"
DEFAULT_PORT = 8080
DEFAULT_STORE_PATH = "./mentipy.json"
DEFAULT_QR_DIR = "./build"
DEFAULT_QR_FORMAT = "pdf"
DEFAULT_MIN_PREFIX = 4

DEFAULT_SETTINGS = {
    BASE_URL_CONFIG: DEFAULT_BASE_URL,
    HOST_CONFIG: DEFAULT_HOST,
    PORT_CONFIG: DEFAULT_PORT,
    STORE_CONFIG: DEFAULT_STORE_PATH,
    QR_DIR_CONFIG: DEFAULT_QR_DIR,
    QR_FORMAT_CONFIG: DEFAULT_QR_FORMAT,
    MIN_PREFIX_CONFIG: DEFAULT_MIN_PREFIX,
}

STORE_TEMPLATE = {"questions": {}, "answers": {}}
@

The environment override makes tests cheap and also gives power users a simple
escape hatch when they want a project-local config file.

<<functions>>=
def config_path() -> Path:
    """Return the configuration file used by mentipy."""

    if override := os.environ.get("MENTIPY_CONFIG"):
        return Path(override)

    dirs = typerconf.appdirs.AppDirs(CONFIG_NAMESPACE)
    return Path(dirs.user_config_dir) / "config.json"
@

The CLI accepts short keys such as [[port]], but the stored JSON keeps them
under the [[mentipy]] namespace so unrelated settings do not collide.

<<functions>>=
def normalize_config_key(key: str) -> str:
    """Return the fully qualified config key for ``key``."""

    if key.startswith(f"{CONFIG_NAMESPACE}."):
        return key
    return f"{CONFIG_NAMESPACE}.{key}"
@

The remaining configuration helpers are thin wrappers around [[typerconf]]'s
[[Config]] object.  They keep the rest of the code free from path juggling and
from repeated JSON parsing.

<<functions>>=
def load_config(*, writeback: bool = False) -> typerconf.Config:
    """Return the mentipy configuration."""

    config = typerconf.Config()
    config.read_config(config_path(), writeback=writeback)
    return config


def get_setting(key: str, default: Any = None) -> Any:
    """Return the configured value for ``key``, or ``default``."""

    full_key = normalize_config_key(key)
    fallback = DEFAULT_SETTINGS.get(full_key, default)

    try:
        return load_config().get(full_key)
    except KeyError:
        return fallback


def set_setting(key: str, value: Any):
    """Store ``value`` under ``key`` in the mentipy configuration."""

    config = load_config(writeback=True)
    config.set(normalize_config_key(key), value)


def list_settings() -> dict[str, Any]:
    """Return the effective values of the built-in mentipy settings."""

    return {
        full_key.split(".", 1)[1]: get_setting(full_key, default)
        for full_key, default in DEFAULT_SETTINGS.items()
    }


def parse_config_value(raw: str) -> Any:
    """Interpret ``raw`` as JSON when possible, else keep it as text."""

    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return raw


def _blank_store() -> dict[str, Any]:
    return {
        "questions": dict(STORE_TEMPLATE["questions"]),
        "answers": dict(STORE_TEMPLATE["answers"]),
    }


def _timestamp() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
@

The store itself is small, but the class boundary matters: the HTTP server, the
LaTeX integration, and the CLI can all share the same persistence rules.

<<classes>>=
class Store:
    """Persist questions and answers in a JSON file."""

    def __init__(self, path: str | Path | None = None, min_prefix: int | None = None):
        chosen_path = path or get_setting(STORE_CONFIG, DEFAULT_STORE_PATH)
        chosen_prefix = min_prefix
        if chosen_prefix is None:
            chosen_prefix = int(
                get_setting(MIN_PREFIX_CONFIG, DEFAULT_MIN_PREFIX)
            )

        self.path = Path(chosen_path)
        self.min_prefix = int(chosen_prefix)
        self._lock = threading.Lock()

    <<store methods>>
@

Reading the store on every operation is the simplest way to make the server see
newly compiled questions without introducing cache invalidation.

<<store methods>>=
def _data(self) -> dict[str, Any]:
    if not self.path.exists():
        return _blank_store()

    with self.path.open(encoding="utf-8") as handle:
        data = json.load(handle)

    data.setdefault("questions", {})
    data.setdefault("answers", {})
    return data


def _write(self, data: dict[str, Any]):
    self.path.parent.mkdir(parents=True, exist_ok=True)
    temp_path = self.path.with_name(f"{self.path.name}.tmp")

    with temp_path.open("w", encoding="utf-8") as handle:
        json.dump(data, handle, ensure_ascii=False, indent=2, sort_keys=True)
        handle.write("\n")

    os.replace(temp_path, self.path)
