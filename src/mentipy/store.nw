\section{Store file primitives}

The empty-store template is copied on demand rather than reused directly, so a
caller who mutates the returned structure cannot accidentally mutate the module
constant used for the next missing file.

<<functions>>=
def _blank_store() -> dict[str, Any]:
    return {
        "questions": dict(STORE_TEMPLATE["questions"]),
        "answers": dict(STORE_TEMPLATE["answers"]),
        REGISTRATION_COUNTER_KEY: STORE_TEMPLATE[REGISTRATION_COUNTER_KEY],
    }


_STORE_LOCKS: dict[Path, threading.Lock] = {}
_STORE_LOCKS_GUARD = threading.Lock()


def _store_lock(path: Path) -> threading.Lock:
    resolved = path.resolve()
    with _STORE_LOCKS_GUARD:
        lock = _STORE_LOCKS.get(resolved)
        if lock is None:
            lock = threading.Lock()
            _STORE_LOCKS[resolved] = lock
    return lock
def _live_hashes(data: dict[str, Any]) -> list[str]:
    items = list(data["questions"].items())
    if not items:
        return []

    live = [items[-1][0]]
    expected = int(items[-1][1][REGISTRATION_SERIAL_KEY])

    for full_hash, meta in reversed(items[:-1]):
        serial = int(meta[REGISTRATION_SERIAL_KEY])
        if serial + 1 != expected:
            break
        live.append(full_hash)
        expected = serial

    live.reverse()
    return live


def _ensure_registration_serials(data: dict[str, Any]):
    counter = int(data.get(REGISTRATION_COUNTER_KEY, 0))
    for fallback, meta in enumerate(data["questions"].values(), start=1):
        if REGISTRATION_SERIAL_KEY not in meta:
            meta[REGISTRATION_SERIAL_KEY] = fallback
        counter = max(counter, int(meta[REGISTRATION_SERIAL_KEY]))
    data[REGISTRATION_COUNTER_KEY] = counter
